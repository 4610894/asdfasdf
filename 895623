    # =========== FUNÇÕES TREEVIEW =========== #
    def _consultar_contas(self):
        """Consulta as contas cadastradas na data atual no banco de dados, atualiza a
        Treeview com os registros encontrados e exibe um resumo no log.
        """

        conn = self.db_manager.conn
        cursor = conn.cursor()

        sac = self.sac_var.get()
        mov = self.conta_mov_var.get()
        esp = self.conta_esp_var.get()

        query = f"""
            SELECT *
            FROM liq.RELACAO_CLIENTES_INR
        """

        if sac or mov or esp:
            query += "WHERE "

            if sac:
                query += f"cd_sac LIKE '%{sac}%' AND "

            if mov:
                query += f"conta_movimento LIKE '%{mov}%' AND "

            if esp:
                query += f"conta_espelho LIKE '%{esp}%'"

        if query.endswith('AND '): query = query[:-4]

        cursor.execute(query)
        registros = cursor.fetchall()

        # limpa treeview
        for item in self.tree.get_children():
            self.tree.delete(item)

        # insere registros aplicando as tags zebradas
        for index, (sac, conta_mov, conta_esp) in enumerate(registros):
            tag = 'par' if index % 2 == 0 else 'impar'
            self.tree.insert("", "end", values=(sac, conta_mov, conta_esp), tags=(tag,))


    def _alterar_dados(self):
        """
        Permite editar ou excluir um registro selecionado na Treeview. Abre uma janela
        pop-up com campos para alteração dos dados e botões para salvar ou deletar o
        registro no banco de dados.
        """
        selecionado = self.tree.selection()
        if not selecionado:
            return

        item = self.tree.item(selecionado[0], "values")
        sac_atual, conta_mov_atual, conta_esp_atual = item

        # --- Janela pop-up de edição ---
        edit_window = ctk.CTkToplevel(self)
        edit_window.title("Editar Registro")
        edit_window.grab_set() # Impede iteração com a janela principal
        edit_window.focus_force() # Garante que a janela fique em evidência

        ctk.CTkLabel(edit_window, text="SAC").grid(row=0, column=0, padx=10, pady=5)
        sac_entry = ctk.CTkEntry(edit_window)
        sac_entry.insert(0, sac_atual)
        sac_entry.grid(row=0, column=1, padx=10, pady=5)

        ctk.CTkLabel(edit_window, text="Conta Movimento").grid(row=1, column=0, padx=10, pady=5)
        conta_mov_entry = ctk.CTkEntry(edit_window)
        conta_mov_entry.insert(0, conta_mov_atual)
        conta_mov_entry.grid(row=1, column=1, padx=10, pady=5)

        ctk.CTkLabel(edit_window, text="Conta Espelho").grid(row=2, column=0, padx=10, pady=5)
        conta_esp_entry = ctk.CTkEntry(edit_window)
        conta_esp_entry.insert(0, conta_esp_atual)
        conta_esp_entry.grid(row=2, column=1, padx=10, pady=5)

        def salvar():
            novo_sac = sac_entry.get().strip()
            novo_conta_mov = conta_mov_entry.get()
            nova_conta_esp = conta_esp_entry.get()

            # Remove barras, traços e espaços para validação
            conta_mov_limpa = novo_conta_mov.replace('/', '').replace('-', '').strip()
            conta_esp_limpa = nova_conta_esp.replace('/', '').replace('-', '').strip()

            if len(conta_mov_limpa) != 10 or not conta_mov_limpa.isdigit():
                messagebox.showwarning("Aviso", "A Conta Movimento deve conter exatamente 10 números.\nEx: 1234/56789-0", parent=edit_window)
                return

            if len(conta_esp_limpa) != 10 or not conta_esp_limpa.isdigit():
                messagebox.showwarning("Aviso", "A Conta Espelho deve conter exatamente 10 números.\nEx: 1234/56789-0", parent=edit_window)
                return

            if not novo_sac:
                messagebox.showwarning("Aviso", "O campo SAC não pode ficar vazio.", parent=edit_window)
                return

            # Formata a conta no padrão correto para o banco
            conta_mov_formatada = f"{conta_mov_limpa[:4]}/{conta_mov_limpa[4:9]}-{conta_mov_limpa[-1]}"
            conta_esp_formatada = f"{conta_esp_limpa[:4]}/{conta_esp_limpa[4:9]}-{conta_esp_limpa[-1]}"

            conn = self.db_manager.conn
            cursor = conn.cursor()

            query = f"""
                UPDATE liq.RELACAO_CLIENTES_INR
                SET cd_sac = ?, conta_movimento = ?, conta_espelho = ?
                WHERE cd_sac = ?
            """

            cursor.execute(query, (novo_sac, conta_mov_formatada, conta_esp_formatada, sac_atual))
            conn.commit()

            # Atualiza treeview e emite mensagem de sucesso
            self.tree.item(selecionado[0], values=(novo_sac, conta_mov_formatada, conta_esp_formatada))
            messagebox.showinfo("Sucesso", "Registro alterado com sucesso!", parent=edit_window)
            edit_window.destroy()

        def deletar():
            # Janela de confirmação
            if messagebox.askyesno("Confirmar", "Tem certeza que deseja deletar este registro?", parent=edit_window):
                conn = self.db_manager.conn
                cursor = conn.cursor()

                query = f"""
                    DELETE FROM liq.RELACAO_CLIENTES_INR
                    WHERE cd_sac = ?
                """
                cursor.execute(query, sac_atual)
                conn.commit()

                # Atualiza treeview e emite mensagem de sucesso
                self.tree.delete(selecionado[0])
                messagebox.showinfo("Sucesso", "Registro deletado com sucesso!", parent=self)
                edit_window.destroy()

        ctk.CTkButton(edit_window, text="Salvar alteração", command=salvar, fg_color=config.AZUL, hover_color=config.AZUL_HOVER).grid(row=3, column=0, padx=10, pady=10)
        ctk.CTkButton(edit_window, text="Deletar", command=deletar, fg_color="red").grid(row=3, column=1, padx=10, pady=10)


    # ========== FUNÇÕES LÓGICA DE NEGÓCIO ========== #
    def _inserir_dados(self):
        edit_window = ctk.CTkToplevel(self)
        edit_window.title("Novo Registro")
        edit_window.grab_set() # Fica na frente e impede clique na janela de trás
        edit_window.focus_force()

        ctk.CTkLabel(edit_window, text="SAC").grid(row=0, column=0, padx=10, pady=5)
        sac_entry = ctk.CTkEntry(edit_window)
        sac_entry.grid(row=0, column=1, padx=10, pady=5)

        ctk.CTkLabel(edit_window, text="Conta Movimento").grid(row=1, column=0, padx=10, pady=5)
        conta_mov_entry = ctk.CTkEntry(edit_window)
        conta_mov_entry.grid(row=1, column=1, padx=10, pady=5)

        ctk.CTkLabel(edit_window, text="Conta Espelho").grid(row=2, column=0, padx=10, pady=5)
        conta_esp_entry = ctk.CTkEntry(edit_window)
        conta_esp_entry.grid(row=2, column=1, padx=10, pady=5)

        def salvar():
            novo_sac = sac_entry.get().strip()
            novo_conta_mov = conta_mov_entry.get()
            nova_conta_esp = conta_esp_entry.get()

            # Remove barras, traços e espaços para validação
            conta_mov_limpa = novo_conta_mov.replace('/', '').replace('-', '').strip()
            conta_esp_limpa = nova_conta_esp.replace('/', '').replace('-', '').strip()

            if len(conta_mov_limpa) != 10 or not conta_mov_limpa.isdigit():
                messagebox.showwarning("Aviso", "A Conta Movimento deve conter exatamente 10 números.\nEx: 1234/56789-0", parent=edit_window)
                return

            if len(conta_esp_limpa) != 10 or not conta_esp_limpa.isdigit():
                messagebox.showwarning("Aviso", "A Conta Espelho deve conter exatamente 10 números.\nEx: 1234/56789-0", parent=edit_window)
                return
            
            if not novo_sac:
                messagebox.showwarning("Aviso", "O campo SAC não pode ficar vazio.", parent=edit_window)
                return

            # Passando as contas limpas. A função _inserir_bd já se encarrega de aplicar a formatação
            sucesso = self._inserir_bd(novo_sac, conta_mov_limpa, conta_esp_limpa)
            if sucesso:
                messagebox.showinfo("Sucesso", "Registro inserido com sucesso!", parent=edit_window)
                edit_window.destroy()
                self._consultar_contas() # Atualiza a tabela para mostrar o novo registro

        # Botão centralizado na parte inferior (usando columnspan=2)
        ctk.CTkButton(edit_window, text="Salvar alteração", command=salvar, fg_color=config.AZUL, hover_color=config.AZUL_HOVER).grid(row=3, column=0, columnspan=2, padx=10, pady=15)

    def _inserir_bd(self, sac, conta_mov, conta_esp):
        """Insere um registro no banco de dados com os dados informados.

        Retorna True se for bem sucedido, False caso contrário.
        """

        if not self.db_manager or not self.db_manager.is_connected():
            self.logger.log("ERRO: Não é possível inserir. Sem conexão com o banco de dados.")
            return False

        # Formata as strings limpas que foram enviadas pelo _inserir_dados
        conta_mov = conta_mov[:4] + '/' + conta_mov[4:9] + '-' + conta_mov[-1]
        conta_esp = conta_esp[:4] + '/' + conta_esp[4:9] + '-' + conta_esp[-1]

        try:
            cursor = self.db_manager.cursor

            # Verifica duplicatas
            query_check = f"SELECT COUNT(*) FROM liq.RELACAO_CLIENTES_INR WHERE cd_sac = ?"
            cursor.execute(query_check, sac)

            if cursor.fetchone()[0] > 0:
                messagebox.showwarning("Aviso", "Este SAC já está registrado!")
                return False

            # Insere o registro
            query = f"""INSERT INTO liq.RELACAO_CLIENTES_INR (cd_sac, conta_movimento, conta_espelho) VALUES (?, ?, ?)"""
            cursor.execute(query, (sac, conta_mov, conta_esp))
            self.db_manager.conn.commit()

            return True
        except pyodbc.Error as e:
            self.logger.log(f"ERRO CRÍTICO ao inserir a conta {sac}: {e}")
            return False
        except Exception as e:
            self.logger.log(f"ERRO INESPERADO ao inserir a conta {sac}: {e}")
            return False
