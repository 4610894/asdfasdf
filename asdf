import json

caminho_arquivo = 'base_marco_liquidacoes.json'

def ler_numero(valor):
    """Garante que o valor seja convertido para float, mesmo se vier como texto do Brasil."""
    if valor is None:
        return 0.0
    if isinstance(valor, (int, float)):
        return float(valor)
    
    # Limpa formatação brasileira caso seja string
    limpo = str(valor).replace('R$', '').replace(' ', '')
    limpo = limpo.replace('.', '').replace(',', '.')
    
    try:
        return float(limpo)
    except ValueError:
        return 0.0

try:
    with open(caminho_arquivo, 'r', encoding='utf-8') as f:
        dados = json.load(f)

    volume_apos_20h = 0.0
    qtd_operacoes = 0

    for linha in dados:
        # Pega a hora e garante que não dê erro se vier vazio
        hr = str(linha.get('Hr Recepção', ''))
        
        if hr >= '20:00':
            valor = ler_numero(linha.get('Financeiro', 0))
            volume_apos_20h += valor
            qtd_operacoes += 1

    # Formata a saída no padrão brasileiro para facilitar a leitura
    moeda = f"R$ {volume_apos_20h:,.2f}".replace(",", "X").replace(".", ",").replace("X", ".")

    print("-" * 40)
    print("CONFERÊNCIA: OPERAÇÕES APÓS 20:00")
    print("-" * 40)
    print(f"Total de Operações: {qtd_operacoes}")
    print(f"Volume Financeiro:  {moeda}")
    print("-" * 40)

except FileNotFoundError:
    print(f"Arquivo '{caminho_arquivo}' não encontrado. Execute o script na mesma pasta do JSON.")
