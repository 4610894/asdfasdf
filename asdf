<script>
    // Injeção do Python (MANTENHA ISSO)
    const BASE_ORIGINAL = __DADOS_JSON__;
    
    // Variável para lidar com os filtros
    let dadosAtuais = BASE_ORIGINAL;

    // Função auxiliar para formatar dinheiro (Ex: R$ 3.400.000,00)
    const formatarDinheiro = (valor) => {
        return new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(valor);
    };

    // Função principal que lê o JSON e constrói o dashboard
    function renderizarDashboard(dados) {
        if (!dados || dados.length === 0) return;

        let totalFinanceiro = 0;
        let operacoesApos18 = 0;
        let maiorLeadTime = 0;
        let financeiroPorCliente = {}; // Para achar o maior cliente

        const tbOperacoes = document.getElementById('tbOperacoes');
        tbOperacoes.innerHTML = ''; // Limpa a tabela

        // 1. Loop principal pelos dados
        dados.forEach(linha => {
            // Tratamento de conversão (caso os números venham como string do JSON)
            let valorFin = parseFloat(linha['financeiro']) || 0;
            let leadTime = parseFloat(linha['lead time min']) || 0;
            let cliente = linha['cliente'] || linha['razão social do cliente'] || 'Desconhecido';
            let faixa = linha['faixa horário'] || '';

            // Cálculos para os KPIs
            totalFinanceiro += valorFin;
            
            if (faixa >= '18:00') {
                operacoesApos18++;
            }

            if (leadTime > maiorLeadTime) {
                maiorLeadTime = leadTime;
            }

            // Agrupamento para descobrir o maior cliente
            if (!financeiroPorCliente[cliente]) {
                financeiroPorCliente[cliente] = 0;
            }
            financeiroPorCliente[cliente] += valorFin;

            // Preenchendo a tabela de Operações
            let tr = document.createElement('tr');
            tr.innerHTML = `
                <td>${linha['data da operação']}</td>
                <td>${cliente}</td>
                <td>${faixa}</td>
                <td>${formatarDinheiro(valorFin)}</td>
                <td>${leadTime} min</td>
            `;
            tbOperacoes.appendChild(tr);
        });

        // 2. Encontrar o maior cliente
        let maiorCliente = "";
        let maxValorCliente = 0;
        for (const [cli, valor] of Object.entries(financeiroPorCliente)) {
            if (valor > maxValorCliente) {
                maxValorCliente = valor;
                maiorCliente = cli;
            }
        }

        // 3. Atualizar os Cards (Visão Executiva) no HTML
        document.getElementById('kpiFinanceiro').innerText = formatarDinheiro(totalFinanceiro);
        document.getElementById('kpiOperacoes').innerText = dados.length;
        
        let percApos18 = ((operacoesApos18 / dados.length) * 100).toFixed(0);
        document.getElementById('kpiApos18').innerText = `${percApos18}%`;
        
        document.getElementById('kpiMaiorClienteNome').innerText = maiorCliente;
        document.getElementById('kpiLeadTime').innerText = `${maiorLeadTime} min`;

        // Aqui você pode adicionar as lógicas para preencher as tabelas de Clientes e Risco 
        // usando a mesma lógica de tbOperacoes.innerHTML = ...
    }

    // Navegação das abas (seu código original)
    function showTab(id) {
        document.querySelectorAll('.tab').forEach(t => t.classList.add('hidden'));
        document.getElementById(id).classList.remove('hidden');
    }

    // Funcionalidade de Filtros reais
    function applyFilters() {
        let fData = document.getElementById('fData').value; // Ex: 2026-03-25
        // Nota: A data do HTML vem no formato YYYY-MM-DD. Adapte dependendo de como está no seu JSON.
        
        let fFaixa = document.getElementById('fFaixa').value;
        let fCliente = document.getElementById('fCliente').value;

        // Filtra a base original
        dadosAtuais = BASE_ORIGINAL.filter(linha => {
            let passaData = true; // Se não escolheu data, passa tudo
            if (fData) {
                // Você pode precisar formatar a data aqui dependendo do formato do seu JSON
                passaData = linha['data da operação'].includes(fData); 
            }
            
            let passaFaixa = (fFaixa === 'ALL') || (linha['faixa horário'] === fFaixa);
            let passaCliente = (fCliente === 'ALL') || (linha['cliente'] === fCliente);

            return passaData && passaFaixa && passaCliente;
        });

        // Re-renderiza o dashboard com os dados filtrados
        renderizarDashboard(dadosAtuais);
    }

    function resetFilters() {
        document.getElementById('fData').value = '';
        document.getElementById('fFaixa').value = 'ALL';
        document.getElementById('fCliente').value = 'ALL';
        
        dadosAtuais = BASE_ORIGINAL;
        renderizarDashboard(dadosAtuais);
    }

    // Assim que a página carrega, ele renderiza o dashboard
    window.onload = () => {
        // Opcional: Popular o select de clientes dinamicamente
        const selectCliente = document.getElementById('fCliente');
        const clientesUnicos = [...new Set(BASE_ORIGINAL.map(item => item['cliente'] || item['razão social do cliente']))].sort();
        clientesUnicos.forEach(cli => {
            if(cli) selectCliente.innerHTML += `<option value="${cli}">${cli}</option>`;
        });

        renderizarDashboard(BASE_ORIGINAL);
    };
</script>
