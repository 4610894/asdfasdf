class GenericWorker(QThread):
    log_signal = Signal(str)
    finished_signal = Signal()

    def __init__(self, funcao_alvo, *args, **kwargs):
        """
        Recebe qual função deverá ser executada e os parâmetros dela.
        """
        super().__init__()
        self.funcao_alvo = funcao_alvo
        self.args = args
        self.kwargs = kwargs

    def run(self):
        # Executa a função passando o próprio worker como primeiro argumento,
        # além dos outros argumentos que foram passados na criação.
        self.funcao_alvo(self, *self.args, **self.kwargs)
        
        # Emite o sinal de que o processo acabou
        self.finished_signal.emit()

