    def inserir_dados(self):
        """
        Insere os dados pela primeira vez no dia
        """
        cursor = self.db_manager.conn.cursor()

        # Verifica se já existem registros para hoje
        query = """
            SELECT data
            FROM liq.CHECKLIST_EXECUCAO
            WHERE data = ?
        """
        cursor.execute(query, (config.HOJE,))

        dados = cursor.fetchall()
        
        if not dados:
            # Busca todos os IDs de tarefas que não são esporádicas
            query = """
                SELECT id 
                FROM liq.CHECKLIST_TAREFAS 
                WHERE esteira NOT LIKE 'ES - %'
            """
            cursor.execute(query)
            tarefas = cursor.fetchall()

            # Insere cada tarefa na execução de hoje
            for tarefa in tarefas:
                id_tarefa = tarefa[0]
                
                query = """
                    INSERT INTO liq.CHECKLIST_EXECUCAO (id_tarefa, data)
                    VALUES (?, ?)
                """
                cursor.execute(query, (id_tarefa, config.HOJE))
                
            self.db_manager.conn.commit()


    def _filtrar(self, *args):
        """Aplica os filtros e insere os dados na treeview."""
        bruto = self.data_var.get()
        if bruto:
            # Remove qualquer caracter que não seja número
            numeros = ''.join(filter(str.isdigit, bruto))
            if len(numeros) == 8:
                dd = numeros[:2]
                mm = numeros[2:4]
                aaaa = numeros[4:]
                
                # Só considera válido se estiver completo
                data_iso = f"{aaaa}-{mm}-{dd}" if len(aaaa) == 4 else ""
            else:
                data_iso = "" # ou o backend exigir string
        else:
            data_iso = ""

        nome_aba = self.esteira_var.get()
        esteira_param = None if nome_aba == "Todas" else nome_aba

        dados = self._consultar_checklist(
            data=data_iso,
            status=self.status_var.get(),
            tarefa=self.nome_tarefa_var.get(),
            esteira=esteira_param
        )
        
        # Limpa as listas
        for tree in self.treeviews.values():
            tree.delete(*tree.get_children())

        # Oculta todos os frames de abas
        for frame in self.abas_frames.values():
            frame.pack_forget()
            
        # Mostra apenas o frame da aba selecionada
        if nome_aba in self.abas_frames:
             self.abas_frames[nome_aba].pack(fill="both", expand=True)

        tree = self.treeviews.get(nome_aba)
        
        if tree:
            for i, linha in enumerate(dados):
                tag = "even" if i % 2 == 0 else "odd"
                
                # Se for aba específica (não "Todas"), remova o último elemento (Esteira)
                if nome_aba != "Todas":
                    # Assumindo que a ordem da query é:
                    # id, tarefa, data, status, resp, obs, data_atual, esteira
                    # Exclui o item[7] (Esteira)
                    valores = (
                        linha.get('id_tarefa', ""),
                        linha.get('tarefa', ""),
                        linha.get('data_evento', ""),
                        linha.get('status', ""),
                        linha.get('responsavel', ""),
                        linha.get('observacoes', ""),
                        linha.get('data_atualizacao', "")
                    )
                else:
                    valores = (
                        linha.get('id_tarefa', ""),
                        linha.get('tarefa', ""),
                        linha.get('data_evento', ""),
                        linha.get('status', ""),
                        linha.get('responsavel', ""),
                        linha.get('observacoes', ""),
                        linha.get('data_atualizacao', ""),
                        linha.get('esteira', "")
                    )
                
                tree.insert("", "end", values=valores, tags=(tag,))
                
        self._aplicar_listras(tree)


    def _aplicar_listras(self, treeview: ttk.Treeview):
        """Aplica as cores alternadas nas linhas da treeview"""
        children = treeview.get_children()
        for i, iid in enumerate(children):
            tag = "even" if i % 2 == 0 else "odd"
            treeview.item(iid, tags=(tag,))


    def _consultar_checklist(self, data=None, status=None, tarefa=None, esteira=None):
        cursor = self.db_manager.conn.cursor()

        query = """
            SELECT t.id AS id_tarefa, t.tarefa, t.esteira, t.data AS data_evento, e.status, 
                   e.responsavel,
                   e.observacoes, e.data_atualizacao
            FROM liq.CHECKLIST_EXECUCAO e
            JOIN liq.CHECKLIST_TAREFAS t ON e.id_tarefa = t.id
            WHERE 1=1
        """
        params = []
        
        if data:
            query += " AND e.data = ?"
            params.append(data)

        if status and status != "Todos":
            query += " AND e.status = ?"
            params.append(status)

        if tarefa:
            query += " AND t.tarefa LIKE ?"
            params.append(f"%{tarefa}%")
            
        if esteira:
            esteira_conditions = []
            if esteira == "Pendente":
                esteira_conditions.append("t.esteira LIKE 'ES - %'")
            else:
                esteira_conditions.append("t.esteira = ?")
                params.append(esteira)
            
            if esteira_conditions:
                 query += " AND (" + " OR ".join(esteira_conditions) + ")"
                 
        query += " ORDER BY t.horario_conclusao"
                 
        cursor.execute(query, params)
        
        col_names = [desc[0] for desc in cursor.description]
        resultados = [dict(zip(col_names, row)) for row in cursor.fetchall()]
        
        return resultados


    def _atualizar_painel(self):
        self._filtrar()
        
    def _editor_celula(self, event):
        """
        Inicia a edição de uma célula com dois cliques.
        """
        # Garante apenas um editor por vez: fecha o anterior salvando (ou mude para salvar=False se preferir descartar)
        if self._cell_editor_info:
            self._fechar_editor_atual(salvar=True)
            
        aba_atual = self.esteira_var.get()
        tree = self.treeviews.get(aba_atual)
        
        if not tree:
            return

        region = tree.identify("region", event.x, event.y)
        if region != "cell":
            return

        col_id = tree.identify_column(event.x)
        col_index = int(col_id.replace("#", "")) - 1
        
        # Colunas editáveis: Status (3), Responsável (4), Observação (5)
        # Atenção aos índices, já que 'ID Tarefa' é 0
        if col_index not in (3, 4, 5): 
            return

        row_id = tree.identify_row(event.y)
        if not row_id:
            return

        bbox = tree.bbox(row_id, col_id)
        if not bbox:
            return
            
        x, y, width, height = bbox
        valores = tree.item(row_id, "values")
        valor_atual = valores[col_index]
        
        # Cria o editor (somente se puder ver)
        if col_index == 3: # Status
            opcoes = ["", "Pendente", "Em andamento", "Concluído", "Não se aplica"]
            editor = ttk.Combobox(tree, values=opcoes, state="readonly")
            editor.set(valor_atual)
        else:
            editor = ttk.Entry(tree)
            editor.insert(0, valor_atual)

        editor.place(x=x, y=y, width=width, height=height)
        editor.focus_set()

        if isinstance(editor, ttk.Entry):
            editor.select_range(0, "end")

        # Guarda referências do editor atual
        self._cell_editor_info = {
            "widget": editor,
            "row_id": row_id,
            "col_id": col_id,
            "col_index": col_index
        }

        # Handlers
        # Garante que só salva se este editor ainda é o ativo
        def salvar_edicao(event=None):
            if self._cell_editor_info and self._cell_editor_info["widget"] == editor:
                self._fechar_editor_atual(salvar=True)
                
        def cancelar_edicao(event=None):
            if self._cell_editor_info and self._cell_editor_info["widget"] == editor:
                self._fechar_editor_atual(salvar=False)

        # Binds
        editor.bind("<Return>", salvar_edicao)
        editor.bind("<Escape>", cancelar_edicao)
        
        # Para Entry, salva ao perder foco; para Combobox, commit ao selecionar/Enter
        if isinstance(editor, ttk.Entry):
            editor.bind("<FocusOut>", salvar_edicao)
        elif isinstance(editor, ttk.Combobox):
            editor.bind("<<ComboboxSelected>>", salvar_edicao)


    def _atualizar_status_no_banco(self, id_tarefa, data_evento, novo_status):
        try:
            cursor = self.db_manager.conn.cursor()
            
            query = """
                UPDATE liq.CHECKLIST_EXECUCAO
                SET status = ?, data_atualizacao = SYSDATETIME()
                WHERE id_tarefa = ? AND data = ?
            """
            cursor.execute(query, (novo_status, id_tarefa, data_evento))
