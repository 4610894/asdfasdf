    def _formatar_data_atualizacao(self, valor):
        if not valor:
             return ""
        
        if isinstance(valor, (datetime, date)):
            return valor.strftime('%d-%m-%Y %H:%M')
            
        # Converte para string
        s = str(valor).strip()
        if not s:
            return ""
        
        # Tenta converter usando lib
        try:
            dt = datetime.fromisoformat(s)
            return dt.strftime("%Y-%m-%d %H:%M")
        except ValueError:
            pass

        # remove microssegundos se houver
        if '.' in s:
            s = s.split('.', 1)[0]

        # Tenta formatos comuns
        formatos = (
            "%Y-%m-%d %H:%M:%S",
            "%Y-%m-%d %H:%M"
        )
        for fmt in formatos:
            try:
                dt = datetime.strptime(s, fmt)
                return dt.strftime("%Y-%m-%d %H:%M")
            except ValueError:
                continue

        return s    
    def _fechar_editor_atual(self, salvar=True):
        """
        Fecha o editor atual (se houver). Se salvar=True, grava as alterações na Treeview e no banco.
        """
        if not self._cell_editor:
            return
        
        editor = self._cell_editor
        info = self._cell_editor_info

        # Zera antes para prevenir reentrância em binds que disparam novamente
        self._cell_editor = None
        self._cell_editor_info = None

        try:
            if salvar and editor.winfo_exists():
                widget = info["widget"]
                row_id = info["row_id"]
                col_index = info["col_index"]

                valores = list(widget.item(row_id, "values"))
                novo_valor = editor.get()
                valores[col_index] = novo_valor
                widget.item(row_id, values=valores)

                id_tarefa = int(valores[0])
                data_evento = valores[2]

                if col_index == 3:
                    self.atualizar_status_no_banco(id_tarefa, data_evento, novo_valor)
                elif col_index == 5:
                    self.atualizar_observacoes_no_banco(id_tarefa, data_evento, novo_valor)
        finally:
            if editor.winfo_exists():
                editor.destroy()
















