    def _processar_e_comparar_dados(self, df_raw, nome_arquivo):
        """
        Aplica o tratamento no DataFrame, compara com a base real (fictícia),
        ordena as prioridades e atualiza o Treeview e os Cards de resumo.
        """
        # 1. Tratamento de dados original
        df = df_raw.copy()
        df['Agência'] = df['Agência'].astype(str).str.zfill(4)
        df['Conta'] = df['Conta'].astype(str).str.zfill(5)
        df['Dac'] = df['Dac'].astype(str).str.zfill(1)
        df['CPF/CNPJ'] = df['CPF/CNPJ'].astype(str).str.zfill(14)

        df['Agência.1'] = df['Agência.1'].astype(str).str.zfill(4)
        df['Conta.1'] = df['Conta.1'].astype(str).str.zfill(5)
        df['Dac.1'] = df['Dac.1'].astype(str).str.zfill(1)
        df['CPF/CNPJ.1'] = df['CPF/CNPJ.1'].astype(str).str.zfill(14)

        df['conta débito'] = df['Agência'] + '/' + df['Conta'] + '-' + df['Dac']
        df['conta crédito'] = df['Agência.1'] + '/' + df['Conta.1'] + '-' + df['Dac.1']

        df = df[['conta débito', 'CPF/CNPJ', 'conta crédito', 'CPF/CNPJ.1', 'Valor']].rename(
            columns={
                'CPF/CNPJ': 'cnpj débito',
                'CPF/CNPJ.1': 'cnpj crédito',
                'Valor': 'valor'
            }
        )

        # 2. Obter a base do banco de dados simulada
        #db_real = self._obter_base_real()
        db_real = self._obter_base_ficticia()

        # 3. Variáveis de controle
        total_operacoes = len(df)
        qtd_batidas = 0
        qtd_nao_encontradas = 0
        qtd_incorretas = 0
        
        # Lista temporária para armazenar e ordenar os dados antes da interface
        linhas_processadas = []
        dados_para_banco = []

        # 4. Lógica de Comparação Linha a Linha
        for index, row in df.iterrows():
            c_debito = row['conta débito']
            cnpj_debito = row['cnpj débito']
            c_credito = row['conta crédito']
            cnpj_credito = row['cnpj crédito']
            valor = row['valor']

            # Validar Débito
            status_deb = "OK"
            if c_debito not in db_real:
                status_deb = "NÃO ENCONTRADA"
            elif db_real[c_debito] != cnpj_debito:
                status_deb = "INCORRETA"

            # Validar Crédito
            status_cred = "OK"
            if c_credito not in db_real:
                status_cred = "NÃO ENCONTRADA"
            elif db_real[c_credito] != cnpj_credito:
                status_cred = "INCORRETA"

            # Definir o Status Final, Cor e Prioridade de Ordenação
            if status_deb == "OK" and status_cred == "OK":
                status_final = "✅ Batida"
                observacao = "OK"
                qtd_batidas += 1
                tag_visual = 'normal' # Marcador temporário para o zebrado
                prioridade = 3

                dados_para_banco.append({
                    'conta_debito': c_debito,
                    'cnpj_debito': cnpj_debito,
                    'conta_credito': c_credito,
                    'cnpj_credito': cnpj_credito,
                    'valor': valor,
                    'status': 'Batida', 
                    'observacao': observacao
                })
                
            elif "NÃO ENCONTRADA" in status_deb or "NÃO ENCONTRADA" in status_cred:
                status_final = "⚠️ Não encontrada"
                observacao = f"D: {status_deb} | C: {status_cred}"
                qtd_nao_encontradas += 1
                tag_visual = 'nao_encontrada'
                prioridade = 2

                # ADICIONADO: Guarda a informação do erro para gravar no banco depois
                dados_para_banco.append({
                    'conta_debito': c_debito,
                    'cnpj_debito': cnpj_debito,
                    'conta_credito': c_credito,
                    'cnpj_credito': cnpj_credito,
                    'valor': valor,
                    'status': status_final.replace('✅ ', '').replace('⚠️ ', '').replace('❌ ', ''), 
                    'observacao': observacao
                })
            else:
                status_final = "❌ Incorreta"
                observacao = f"D: {status_deb} | C: {status_cred}"
                qtd_incorretas += 1
                tag_visual = 'incorreta'
                prioridade = 1

                # ADICIONADO: Guarda a informação do erro para gravar no banco depois
                dados_para_banco.append({
                    'conta_debito': c_debito,
                    'cnpj_debito': cnpj_debito,
                    'conta_credito': c_credito,
                    'cnpj_credito': cnpj_credito,
                    'valor': valor,
                    'status': status_final.replace('✅ ', '').replace('⚠️ ', '').replace('❌ ', ''), 
                    'observacao': observacao
                })

            # Salva os dados na lista em vez de jogar direto na tela
            linhas_processadas.append({
                'valores': (c_debito, cnpj_debito, c_credito, cnpj_credito, valor, status_final, observacao, '☐', '☐'),
                'tag_visual': tag_visual,
                'prioridade': prioridade
            })

        # 5. Ordena a lista usando a prioridade (1 aparece primeiro, depois 2, depois 3)
        linhas_processadas.sort(key=lambda x: x['prioridade'])

        # 6. Limpa o Treeview antes de inserir a nova remessa de dados
        for item in self.tree.get_children():
            self.tree.delete(item)

        # 7. Insere as linhas ordenadas no Treeview com o zebrado dinâmico
        for index, item in enumerate(linhas_processadas):
            tag_base = item['tag_visual']
            
            # Verifica se a linha final na tabela é par ou ímpar
            sufixo = '_par' if index % 2 == 0 else '_impar'
            
            # Define a tag final baseada no status
            if tag_base == 'normal':
                # Se for normal, usa apenas 'par' ou 'impar'
                tag_final = 'par' if index % 2 == 0 else 'impar'
            else:
                # Se for erro, junta a base com o sufixo (ex: 'incorreta_par', 'nao_encontrada_impar')
                tag_final = f"{tag_base}{sufixo}"
                
            self.tree.insert('', 'end', values=item['valores'], tags=(tag_final,))

        # 8. Atualiza as caixas superiores (Cards)
        self.val_operacoes.set(str(total_operacoes))
        self.val_batidas.set(str(qtd_batidas))
        self.val_nao_encontradas.set(str(qtd_nao_encontradas))
        self.val_incorretas.set(str(qtd_incorretas))

        # ADICIONADO: Chamada final para salvar tudo no banco de dados
        self._registrar_log(nome_arquivo, dados_para_banco)

    def _registrar_log(self, nome_arquivo, linhas_completas):
        """
        Gera um novo id_lote e registra todas as linhas na tabela única.
        """
        data_hora_atual = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
        id_usuario = getattr(self, 'usuario_logado', 'SISTEMA')
        cursor = self.db_manager.cursor

        try:
            # 1. Buscar o id do último lote
            cursor.execute("SELECT MAX(id_lote) FROM liq.BATIMENTO_OM5")
            resultado = cursor.fetchone()
            ultimo_id = resultado[0] if resultado and resultado[0] is not None else 0
            
            # Novo ID
            novo_id_lote = ultimo_id + 1
            self.id_lote_atual = novo_id_lote

            # 2. Inserir todos os registros de uma vez na nova tabela única
            if linhas_completas:
                query_insert = """
                    INSERT INTO liq.BATIMENTO_OM5 
                    (id_lote, responsavel, nome_arquivo, conta_debito, cnpj_debito, 
                     conta_credito, cnpj_credito, valor, status, observacao, data_upload)
                    VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
                """
                
                valores_insert = [
                    (novo_id_lote, id_usuario, nome_arquivo, linha['conta_debito'], 
                     linha['cnpj_debito'], linha['conta_credito'], linha['cnpj_credito'], 
                     linha['valor'],
                     linha['status'], linha['observacao'], data_hora_atual)
                    for linha in linhas_completas
                ]
                
                cursor.executemany(query_insert, valores_insert)

            self.db_manager.commit()
            
        except Exception as e:
            self.db_manager.rollback()
            print(f"Erro ao salvar lote no banco de dados: {e}")

    def _obter_base_real(self):
        """
        Conecta no AWS Athena, consulta a base de contas e CNPJs
        e retorna um dicionário no formato: {'0123/01234-1': '00000000012345'}
        """
        # --- CONFIGURAÇÕES DA AWS ---
        # Substitua pelas informações do seu ambiente
        nome_da_regiao = "sa-east-1" # Ex: São Paulo
        bucket_resultados = "s3://seu-bucket-de-query-results-athena/" 
        
        try:
            # Estabelece a conexão com o Athena
            # Ele vai buscar automaticamente suas credenciais configuradas na máquina (AWS CLI)
            # conn = connect(s3_staging_dir=bucket_resultados, region_name=nome_da_regiao)
            conn = None
            
            # --- SUA QUERY SQL ---
            # Ajuste 'seu_database.sua_tabela' e o nome exato das colunas
            query = """
                SELECT 
                    agencia, 
                    conta, 
                    dac, 
                    cnpj 
                FROM seu_database.sua_tabela_de_contas
            """
            
            # Executa a query e joga o resultado direto em um DataFrame do Pandas!
            df_athena = pd.read_sql(query, conn)
            
            # --- TRANSFORMAR NO DICIONÁRIO ---
            base_real = {}
            for index, row in df_athena.iterrows():
                # Padronizando os dados do banco da mesma forma que padronizamos o Excel
                ag = str(row['agencia']).zfill(4)
                ct = str(row['conta']).zfill(5)
                dc = str(row['dac']).zfill(1)
                cnpj = str(row['cnpj']).zfill(14)
                
                # Monta a chave (ex: 0123/01234-1)
                conta_formatada = f"{ag}/{ct}-{dc}"
                
                # Salva no dicionário
                base_real[conta_formatada] = cnpj
                
            return base_real
            
        except Exception as e:
            print(f"Erro ao conectar ou consultar o Athena: {e}")
            # Retorna dicionário vazio em caso de erro para não quebrar o app inteiro
            return {}

