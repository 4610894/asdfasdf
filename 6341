    def _atualizar_credenciais(self):
        """
        Lê os valores inseridos na interface e atualiza o arquivo 'credentials' na pasta .aws.
        """
        key = self.aws_key_entry.get().strip()
        secret = self.aws_secret_entry.get().strip()
        token = self.aws_token_entry.get().strip()

        # Validação simples para evitar salvar arquivo em branco
        if not key or not secret or not token:
            messagebox.showwarning("Atenção", "Preencha todos os campos antes de atualizar.")
            return

        # Busca o caminho do diretório home do usuário e define a pasta .aws
        caminho_aws = os.path.expanduser("~/.aws")
        arquivo_credentials = os.path.join(caminho_aws, "credentials")

        # Texto no formato padrão esperado pela AWS CLI / Boto3 / Athena
        conteudo = f"""[default]
aws_access_key_id = {key}
aws_secret_access_key = {secret}
aws_session_token = {token}
"""
        try:
            # Cria a pasta .aws caso ela não exista
            os.makedirs(caminho_aws, exist_ok=True)
            
            # Sobrescreve (ou cria) o arquivo credentials
            with open(arquivo_credentials, "w", encoding="utf-8") as f:
                f.write(conteudo)
                
            messagebox.showinfo("Sucesso", "Credenciais AWS atualizadas com sucesso!")
            
            # Opcional: Limpar os campos após o sucesso
            self.aws_key_entry.delete(0, 'end')
            self.aws_secret_entry.delete(0, 'end')
            self.aws_token_entry.delete(0, 'end')
            
        except Exception as e:
