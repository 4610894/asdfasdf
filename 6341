            # Como o helper _create_button já define setFixedWidth(150), eles não vão esticar
            top_buttons_container.addWidget(self.btn_salvar)
            top_buttons_container.addWidget(self.btn_buscar)
            top_buttons_container.addWidget(self.btn_excel)
            
            right_column.addLayout(top_buttons_container)

            # Tabela
            right_column.addWidget(QLabel("Contas inseridas hoje:"))
            self.table = QTableWidget(0, 4)
            self.table.setHorizontalHeaderLabels(["Produto", "Nome", "Conta", "Data"])
            self.table.horizontalHeader().setSectionResizeMode(QHeaderView.ResizeMode.Stretch)
            self.table.verticalHeader().setVisible(False)
            right_column.addWidget(self.table)

            # Botões Inferiores - Também centralizados
            bottom_buttons_layout = QHBoxLayout()
            bottom_buttons_layout.setAlignment(Qt.AlignmentFlag.AlignCenter)
            self.btn_consultar = self._create_button("Consultar", "intern/icons/consultar.png", self._consultar_contas)
            self.btn_alterar = self._create_button("Alterar", "intern/icons/alterar.png", self._alterar_dados)
            bottom_buttons_layout.addWidget(self.btn_consultar)
            bottom_buttons_layout.addWidget(self.btn_alterar)
            
            right_column.addLayout(bottom_buttons_layout)

            # Adicionamos ao layout principal com stretch 3 (tabela ainda é larga, mas proporcional ao log)
            content_layout.addLayout(right_column, stretch=3)

            self.main_layout.addWidget(content_container)

    def _create_button(self, text, icon_path, command):
        """Helper para criar botões com tamanho fixo e texto centralizado"""
        btn = QPushButton(text)
        if os.path.exists(icon_path):
            btn.setIcon(QIcon(icon_path))
        btn.setCursor(Qt.CursorShape.PointingHandCursor)
        
        # Mantendo a largura original conforme solicitado
        btn.setFixedWidth(150) 
        btn.setFixedHeight(35)
        
        btn.clicked.connect(command)
        return btn


