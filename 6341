    def _formatar_data_atualizacao(self, valor):
        if not valor:
             return ""
        
        if isinstance(valor, datetime):
            return valor.strftime('%d-%m-%Y %H:%M')
            
        # Se for string tenta converter
        try:
            # Assumindo que vem do SQL Server no formato '2025-05-19 10:45:14.287000'
            dt = datetime.strptime(valor[:19], '%Y-%m-%d %H:%M:%S')
            return dt.strftime('%d-%m-%Y %H:%M')
        except ValueError:
            pass # Se falhar, tenta outros formatos ou retorna original
            
        return valor
        
        
    def _fechar_editor_atual(self, salvar=True):
        """
        Fecha o editor atual (se houver). Se salvar=True, grava as alterações na Treeview e no banco.
        """
        if not self._cell_editor_info:
            return

        info = self._cell_editor_info
        editor = info["widget"]
        row_id = info["row_id"]
        col_id = info["col_id"]
        col_index = info["col_index"]

        # Zera antes para prevenir reentrância em binds que disparam novamente
        self._cell_editor_info = None

        try:
            widget = info["widget"]
            
            if not widget.winfo_exists():
                return
                
            tree_atual = self.treeviews.get(self.esteira_var.get())
            if not tree_atual or not tree_atual.exists(row_id):
                return
                
            if salvar:
                novo_valor = widget.get()
                valores = list(tree_atual.item(row_id, "values"))
                meu_valor = valores[col_index]

                if novo_valor != meu_valor:
                    valores[col_index] = novo_valor
                    tree_atual.item(row_id, values=valores)

                    # Atualiza no banco
                    id_tarefa = valores[0]
                    data_evento = valores[2]

                    if col_index == 3:
                        self._atualizar_status_no_banco(id_tarefa, data_evento, novo_valor)
                    elif col_index == 4:
                        self._atualizar_responsavel_no_banco(id_tarefa, data_evento, novo_valor)
                    elif col_index == 5:
                        self._atualizar_observacoes_no_banco(id_tarefa, data_evento, novo_valor)

        finally:
            editor.destroy()


















