        self.btn_editar.pack(side="right", expand=True, padx=10)

        # Carrega os dados ao iniciar a janela
        self.carregar_dados()
    def carregar_dados(self):
        # Limpa o treeview atual para evitar duplicação visual
        for item in self.tree.get_children():
            self.tree.delete(item)
            
        try:
            conn = self.db_manager.conn
            cursor = conn.cursor()
            cursor.execute("SELECT corretora, email FROM liq.EMAILS_CORRETORAS ORDER BY corretora ASC")
            registros = cursor.fetchall()
            
            for row in registros:
                self.tree.insert("", "end", values=(row[0], row[1]))
        except Exception as e:
            messagebox.showerror("Erro de Leitura", f"Não foi possível carregar os dados: {str(e)}")
    def abrir_inserir(self):
        FormularioEmail(self, self.db_manager, self.carregar_dados)
    def abrir_editar(self):
        item_selecionado = self.tree.selection()
        if not item_selecionado:
            messagebox.showwarning("Aviso", "Selecione uma linha na tabela para editar.")
            return
            
        # Coleta os valores do item selecionado na Treeview
        valores = self.tree.item(item_selecionado[0], "values")
        corretora = valores[0]
        email = valores[1]

        FormularioEmail(self, self.db_manager, self.carregar_dados, corretora_antiga=corretora, email_antigo=email)

