        aba_consulta = tabview.tab("Consulta")

        ctk.CTkLabel(aba_consulta, text="Conta (10 dígitos):", anchor="w", width=250).pack(pady=(20, 0))
        # Adicionado self.
        self.conta_consulta_entry = ctk.CTkEntry(aba_consulta, width=250, border_color=config.AZUL)
        self.conta_consulta_entry.pack(pady=(5, 15))

        ctk.CTkLabel(aba_consulta, text="CNPJ Retornado:", anchor="w", width=250).pack(pady=(10, 0))
        # Adicionado self.
        self.cnpj_consulta_entry = ctk.CTkEntry(aba_consulta, width=250, state="disabled", border_color=config.AZUL)
        self.cnpj_consulta_entry.pack(pady=(5, 30))

