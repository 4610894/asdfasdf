    def run(self):
        try:
            self.toggle_ui(True)

            corretora = self.corretora_var.get()

            if corretora == "Ágora":
                threading.Thread(target=self.BTB_Agora, daemon=True).start()
            
            elif corretora == "Itaú":
                threading.Thread(target=self.BTB_Itau, daemon=True).start()

        except Exception as e:
            self.logger.log(f"Erro: {e}")
            self.toggle_ui(False)

