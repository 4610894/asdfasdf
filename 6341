        email = self.entry_email.get().strip()

        if not corretora or not email:
            messagebox.showwarning("Aviso", "Preencha todos os campos!")
            return

        try:
            conn = self.db_manager.conn
            cursor = conn.cursor()
            cursor.execute("""
                INSERT INTO liq.EMAILS_CORRETORAS (corretora, email) 
                VALUES (?, ?)
            """, (corretora, email))
            conn.commit()
            self.refresh_callback()
            self.destroy()
        # except sqlite3.IntegrityError: # NO PROJETO REAL MUDE PARA: except pyodbc.IntegrityError:
