    def _ao_clicar_na_tabela(self, event):
        """
        Captura o duplo clique na Treeview. Alterna o checkbox e atualiza o banco de dados.
        """
        regiao = self.tree.identify("region", event.x, event.y)
        if regiao != "cell":
            return

        row_id = self.tree.identify_row(event.y)
        column_id = self.tree.identify_column(event.x)

        # '#7' = Coordenador, '#8' = Gerente
        if column_id in ('#7', '#8'):
            valores_atuais = list(self.tree.item(row_id, 'values'))
            indice_coluna = int(column_id.replace('#', '')) - 1

            valor_atual = valores_atuais[indice_coluna]
            novo_valor = '☑' if valor_atual == '☐' else '☐'

            # Atualiza a lista e insere de volta na interface
            valores_atuais[indice_coluna] = novo_valor
            self.tree.item(row_id, values=valores_atuais)

            # --- LÓGICA DE ATUALIZAÇÃO DO BANCO DE DADOS ---
            
            # Coleta as chaves para encontrar a linha no banco
            conta_deb = valores_atuais[0]
            conta_cred = valores_atuais[2]
            
            # Define os valores para o banco: 1 (True) se marcou, 0 (False) se desmarcou
            is_checked = 1 if novo_valor == '☑' else 0
            # Se foi marcado, pega a data/hora atual. Se desmarcou, envia None (vira NULL no banco)
            data_hora = datetime.now().strftime("%Y-%m-%d %H:%M:%S") if is_checked else None

            # Verifica se temos o ID do lote gerado
            id_lote = getattr(self, 'id_lote_atual', None)
            
            if id_lote is None:
                print("Aviso: ID do lote atual não encontrado. A atualização não foi salva no banco.")
                return

            try:
                cursor = self.db_manager.cursor
                
                if column_id == '#7': # Coordenador
                    query = """
                        UPDATE log_detalhes 
                        SET aprov_coord = ?, data_aprov_coord = ?
                        WHERE id_lote = ? AND conta_debito = ? AND conta_credito = ?
                    """
                else: # Gerente
                    query = """
                        UPDATE log_detalhes 
                        SET aprov_geren = ?, data_aprov_geren = ?
                        WHERE id_lote = ? AND conta_debito = ? AND conta_credito = ?
                    """
                
                cursor.execute(query, (is_checked, data_hora, id_lote, conta_deb, conta_cred))
                self.db_manager.commit()
                
            except Exception as e:
                print(f"Erro ao atualizar aprovação no banco de dados: {e}")
                self.db_manager.rollback()

    def _carregar_ultimo_lote_hoje(self):
        """
        Busca o último id_lote salvo com a data de hoje.
        Carrega todos os detalhes no Treeview (incluindo CNPJs) e recarrega os checkboxes.
        """
        cursor = self.db_manager.cursor
        data_hoje = datetime.now().strftime("%Y-%m-%d")

        try:
            # 1. Busca o último lote de hoje na tabela macro
            query_lote = """
                SELECT id_lote, total_operacoes, qtd_batidas, qtd_nao_encontradas, qtd_incorretas 
                FROM log_lotes 
                WHERE data_hora_upload LIKE ? 
                ORDER BY id_lote DESC
            """
            cursor.execute(query_lote, (f"{data_hoje}%",))
            lote_info = cursor.fetchone()

            if not lote_info:
                return

            self.id_lote_atual = lote_info[0]

            # Atualiza os Cards Superiores
            self.val_operacoes.set(str(lote_info[1]))
            self.val_batidas.set(str(lote_info[2]))
            self.val_nao_encontradas.set(str(lote_info[3]))
            self.val_incorretas.set(str(lote_info[4]))

            # 2. Busca os dados da tabela micro (AGORA COM OS CNPJS INCLUÍDOS)
            query_detalhes = """
                SELECT 
                    conta_debito, cnpj_debito, 
                    conta_credito, cnpj_credito, 
                    status_erro, observacao, 
                    aprov_coord, aprov_geren
                FROM log_detalhes
                WHERE id_lote = ?
            """
            cursor.execute(query_detalhes, (self.id_lote_atual,))
            linhas_banco = cursor.fetchall()

            # Limpa a Treeview atual
            for item in self.tree.get_children():
                self.tree.delete(item)

            # 3. Insere os dados recuperados na interface
            for index, row in enumerate(linhas_banco):
                c_debito = row[0]
                cnpj_debito = row[1]
                c_credito = row[2]
                cnpj_credito = row[3]
                status = row[4]
                observacao = row[5]
                
                # Traduz o valor do banco (1/True = Marcado, 0/False/None = Vazio)
                check_coord = '☑' if row[6] else '☐'
                check_geren = '☑' if row[7] else '☐'

                # Recria a lógica visual de zebrado baseado no status
                status_upper = str(status).upper()
                
                # Garante que o emoji não seja duplicado caso já venha do banco
                if "NÃO ENCONTRADA" in status_upper:
                    tag_base = 'nao_encontrada'
                    status_final = f"⚠️ {status}" if "⚠️" not in status else status
                elif "INCORRETA" in status_upper:
                    tag_base = 'incorreta'
                    status_final = f"❌ {status}" if "❌" not in status else status
                else:
                    tag_base = 'normal'
                    status_final = f"✅ {status}" if "✅" not in status else status

                sufixo = '_par' if index % 2 == 0 else '_impar'
                
                if tag_base == 'normal':
                    tag_final = 'par' if index % 2 == 0 else 'impar'
                else:
                    tag_final = f"{tag_base}{sufixo}"

                valores = (c_debito, cnpj_debito, c_credito, cnpj_credito, status_final, observacao, check_coord, check_geren)
                self.tree.insert('', 'end', values=valores, tags=(tag_final,))

        except Exception as e:
            print(f"Erro ao carregar o lote do dia: {e}")
