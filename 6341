    def _registrar_log(self, nome_arquivo, linhas_completas):
        """
        Gera um novo id_lote e registra todas as linhas na tabela única.
        """
        data_hora_atual = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
        id_usuario = getattr(self, 'usuario_logado', 'SISTEMA')
        cursor = self.db_manager.cursor

        try:
            # 1. Buscar o id do último lote
            cursor.execute("SELECT MAX(id_lote) FROM liq.BATIMENTO_OM5")
            resultado = cursor.fetchone()
            ultimo_id = resultado[0] if resultado and resultado[0] is not None else 0
            
            # Novo ID
            novo_id_lote = ultimo_id + 1
            self.id_lote_atual = novo_id_lote

            # 2. Inserir todos os registros de uma vez na nova tabela única
            if linhas_completas:
                query_insert = """
                    INSERT INTO liq.BATIMENTO_OM5 
                    (id_lote, responsavel, nome_arquivo, conta_debito, cnpj_debito, 
                     conta_credito, cnpj_credito, valor, status, observacao, data_upload)
                    VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?, ?)
                """
                
                valores_insert = [
                    (novo_id_lote, id_usuario, nome_arquivo, linha['conta_debito'], 
                     linha['cnpj_debito'], linha['conta_credito'], linha['cnpj_credito'], 
                     linha['valor'],
                     linha['status'], linha['observacao'], data_hora_atual)
                    for linha in linhas_completas
                ]
                
                cursor.executemany(query_insert, valores_insert)

            self.db_manager.commit()
            
        except Exception as e:
            self.db_manager.rollback()
            print(f"Erro ao salvar lote no banco de dados: {e}")

        

