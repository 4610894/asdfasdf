# =====================================================================
# WIDGET CUSTOMIZADO: Gráfico de Progresso Circular
# Substitui o Canvas do Tkinter pelo QPainter do Qt (Alta qualidade)
# =====================================================================
class CircularProgress(QWidget):
    def __init__(self, percentual, parent=None):
        super().__init__(parent)
        self.percentual = percentual
        self.setFixedSize(80, 80) # Mesmo tamanho original

    def paintEvent(self, event):
        painter = QPainter(self)
        painter.setRenderHint(QPainter.RenderHint.Antialiasing)

        rect = QRectF(10, 10, 60, 60)
        
        # Desenha o fundo (círculo completo)
        pen_bg = QPen(QColor("#E5E7EB"), 8, Qt.PenStyle.SolidLine, Qt.PenCapStyle.RoundCap)
        painter.setPen(pen_bg)
        painter.drawArc(rect, 0, 360 * 16)

        # Desenha o progresso
        if self.percentual > 0:
            pen_fg = QPen(QColor("#10B981"), 8, Qt.PenStyle.SolidLine, Qt.PenCapStyle.RoundCap)
            painter.setPen(pen_fg)
            # Qt usa 1/16 de grau. 90 * 16 é o topo. Multiplica por negativo para sentido horário.
            span_angle = int(-360 * self.percentual * 16)
            painter.drawArc(rect, 90 * 16, span_angle)

        # Texto central
        painter.setPen(QColor("#374151"))
        font = QFont("Arial", 16, QFont.Weight.Bold)
        painter.setFont(font)
        painter.drawText(rect, Qt.AlignmentFlag.AlignCenter, f"{int(self.percentual * 100)}%")

