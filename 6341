import os
import win32com.client
import pandas as pd

def buscar_emails_todas_pastas(pasta, titulo_x, titulo_y, melhor_x=None, melhor_y=None):
    """
    Função recursiva que varre a pasta atual e todas as suas subpastas
    em busca dos e-mails mais recentes com os títulos X e Y.
    """
    try:
        itens = pasta.Items
        # Ordena os itens da pasta do mais recente para o mais antigo para otimizar
        itens.Sort("[ReceivedTime]", True)
        
        achou_x_na_pasta = False
        achou_y_na_pasta = False
        
        for item in itens:
            if item.Class == 43:  # 43 refere-se a MailItem (ignora convites de calendário, etc.)
                
                # Verifica E-mail X
                if not achou_x_na_pasta and titulo_x in item.Subject:
                    if melhor_x is None or item.ReceivedTime > melhor_x.ReceivedTime:
                        melhor_x = item
                    achou_x_na_pasta = True # Como a pasta está ordenada, o primeiro que achar aqui é o mais novo desta pasta
                
                # Verifica E-mail Y
                if not achou_y_na_pasta and titulo_y in item.Subject:
                    if melhor_y is None or item.ReceivedTime > melhor_y.ReceivedTime:
                        melhor_y = item
                    achou_y_na_pasta = True
                
                # Se já achou o mais recente de ambos nesta pasta, pode parar de olhar os itens mais antigos dela
                if achou_x_na_pasta and achou_y_na_pasta:
                    break

    except Exception:
        # Algumas pastas de sistema do Outlook não permitem leitura direta, ignoramos silenciosamente
        pass

    # Varre as subpastas recursivamente
    try:
        for subpasta in pasta.Folders:
            melhor_x, melhor_y = buscar_emails_todas_pastas(subpasta, titulo_x, titulo_y, melhor_x, melhor_y)
    except Exception:
        pass

    return melhor_x, melhor_y


def process_emails_and_generate_report():
    print("Iniciando varredura em todas as pastas do Outlook. Isso pode levar alguns segundos...")
    
    # 1. Conectar ao Outlook
    outlook = win32com.client.Dispatch("Outlook.Application").GetNamespace("MAPI")
    
    titulo_x = "X"
    titulo_y = "Y"
    
    email_x = None
    email_y = None

    # Varre todas as contas/caixas de correio conectadas no seu Outlook
    for store in outlook.Stores:
        pasta_raiz = store.GetRootFolder()
        email_x, email_y = buscar_emails_todas_pastas(pasta_raiz, titulo_x, titulo_y, email_x, email_y)

    if not email_x or not email_y:
        print("Não foi possível encontrar ambos os e-mails (X e Y) nas pastas do Outlook.")
        return

    print(f"E-mail X encontrado! Data: {email_x.ReceivedTime}")
    print(f"E-mail Y encontrado! Data: {email_y.ReceivedTime}")

    # Lista para armazenar os caminhos temporários dos anexos
    temp_files = []
    dfs = []

    # 2. Baixar e ler os anexos
    for idx, email in enumerate([email_x, email_y]):
        if email.Attachments.Count > 0:
            for attachment in email.Attachments:
                if attachment.FileName.endswith('.xlsx') or attachment.FileName.endswith('.xls'):
                    temp_path = os.path.join(os.getcwd(), f"temp_anexo_{idx}_{attachment.FileName}")
                    attachment.SaveAsFile(temp_path)
                    temp_files.append(temp_path)
                    
                    # Ler o arquivo Excel
                    df_temp = pd.read_excel(temp_path)
                    dfs.append(df_temp)
                    break # Pega apenas o primeiro arquivo Excel do e-mail

    if len(dfs) < 2:
        print("Não foi possível encontrar anexos Excel em ambos os e-mails.")
        return

    # 3. Concatenar os dataframes
    df_concat = pd.concat(dfs, ignore_index=True)

    # 4. Tratar o dataframe
    colunas_necessarias = ["Conta Custódia", "Corretagem (R$)", "X", "Z"]
    df_filtrado = df_concat[colunas_necessarias].copy()

    df_agrupado = df_filtrado.groupby(["Conta Custódia", "Z", "X"], as_index=False)["Corretagem (R$)"].sum()
    df_ordenado = df_agrupado.sort_values(by=["X", "Conta Custódia"]).reset_index(drop=True)

    # Substitua este bloco pelo carregamento do seu arquivo de depara real
    df_depara = pd.DataFrame({
        "Conta Custódia": df_ordenado["Conta Custódia"].unique(),
        "Nova_Coluna_Depara": [f"Desc_{c}" for c in df_ordenado["Conta Custódia"].unique()]
    })

    df_resultado = pd.merge(df_ordenado, df_depara, on="Conta Custódia", how="left")

    # Escrever o resultado
    output_excel_path = os.path.join(os.getcwd(), "resultado_consolidado.xlsx")
    df_resultado.to_excel(output_excel_path, index=False)
    print(f"Resultado salvo em: {output_excel_path}")

    # Somar valores específicos de Z
    df_resultado['Z_str'] = df_resultado['Z'].astype(str)
    
    soma_4440 = df_resultado[df_resultado['Z_str'] == '4440']['Corretagem (R$)'].sum()
    soma_2028 = df_resultado[df_resultado['Z_str'] == '2028']['Corretagem (R$)'].sum()
    total_geral = soma_4440 + soma_2028

    # 5. Gerar e-mail de resposta
    outlook_app = win32com.client.Dispatch("Outlook.Application")
    new_mail = outlook_app.CreateItem(0)
    new_mail.Subject = "Relatório Consolidado de Corretagem"
    new_mail.To = "destinatario@exemplo.com"
    
    corpo_email = f"""4440: R$ {soma_4440:,.2f}
2028: R$ {soma_2028:,.2f}
total: R$ {total_geral:,.2f}"""

    new_mail.Body = corpo_email
    new_mail.Display()

    # Limpeza dos arquivos temporários
    for file in temp_files:
        try:
            os.remove(file)
        except Exception as e:
            print(f"Aviso: Não foi possível remover o arquivo temporário {file}: {e}")

if __name__ == "__main__":
    process_emails_and_generate_report()
