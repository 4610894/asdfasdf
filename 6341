import customtkinter as ctk

class App(ctk.CTk):
    def __init__(self):
        super().__init__()
        self.geometry("400x200")
        self.title("Máscara CustomTkinter")

        self.label = ctk.CTkLabel(self, text="Digite o código (apenas números):")
        self.label.pack(pady=(20, 0))

        # Variável que rastreia o texto da Entry
        self.entry_var = ctk.StringVar()
        self.entry_var.trace_add("write", self.formatar_entrada)

        self.entry = ctk.CTkEntry(self, textvariable=self.entry_var, width=200)
        self.entry.pack(pady=10)

    def formatar_entrada(self, *args):
        # 1. Pega apenas os números digitados
        texto = "".join(filter(str.isdigit, self.entry_var.get()))
        
        # 2. Limita a quantidade de dígitos (4 + 5 + 1 = 10 dígitos)
        texto = texto[:10]
        
        formato = ""
        for i, char in enumerate(texto):
            if i == 4:
                formato += "/"
            elif i == 9:
                formato += "-"
            formato += char

        # 3. Atualiza a Entry sem disparar o trace infinitamente
        self.entry_var.set(formato)

if __name__ == "__main__":
    app = App()
    app.mainloop()
