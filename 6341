import customtkinter as ctk
import threading

class ProgressWindow(ctk.CTkToplevel):
    def __init__(self, parent, total):
        super().__init__(parent)
        self.title("Processando")
        self.geometry("300x150")
        self.grab_set()  # Bloqueia interação com a janela principal
        
        self.label = ctk.CTkLabel(self, text="Consultando contas...", font=("Arial", 14, "bold"))
        self.label.pack(pady=(20, 10))
        
        # Ícone de carregamento (ProgressBar em modo indeterminado parece um spinner)
        self.spinner = ctk.CTkProgressBar(self, orientation="horizontal", mode="indeterminate")
        self.spinner.pack(pady=10, px=20)
        self.spinner.start()
        
        self.counter_label = ctk.CTkLabel(self, text=f"0 / {total}")
        self.counter_label.pack(pady=10)

    def atualizar(self, atual, total):
        self.counter_label.configure(text=f"{atual} / {total}")







