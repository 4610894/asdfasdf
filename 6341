    def inserir_dados(self):
        return
        """Insere as tarefas diárias pela primeira vez no dia"""
        conn = self.db_manager.conn
        cursor = conn.cursor()

        # Busca todos os IDs de tarefas que não são esporádicas
        query = """
            SELECT id
            FROM liq.CHECKLIST_TAREFAS
            WHERE esteira NOT LIKE 'ES - %'
        """
        cursor.execute(query)
        tarefas = cursor.fetchall()

        # Insere cada tarefa na execução de hoje
        for tarefa in tarefas:
            id_tarefa = tarefa[0]
            query = f"""
                INSERT INTO liq.CHECKLIST_EXECUCAO (id_tarefa, data)
                VALUES ({id_tarefa}, '{config.HOJE}')
            """
            try:
                cursor.execute(query)
            except:
                pass

        conn.commit()
    def filtrar(self):
        """Aplica os filtros e insere os dados na treeview"""
        self.revisar_status()

        # Formatar a data para ISO para a busca
        bruto = (self.data_entry.text() or "").strip()
        partes = bruto.split("/") if "/" in bruto else bruto.split("-")

        dd = partes[0] if len(partes) > 0 else ""
        mm = partes[1] if len(partes) > 1 else ""
        aaaa = partes[2] if len(partes) > 2 else ""

        # Só considera válida se estiver completa
        if len(dd) == 2 and len(mm) == 2 and len(aaaa) == 4:
            data_iso = f"{aaaa}-{mm}-{dd}"
        else:
            data_iso = None  # ou "" se o backend exigir string

        status = self.status_menu.currentText()
        status = None if status == "" else status
        tarefa = self.tarefa_entry.text()

        for nome_aba, table in self.trees.items():
            esteira_param = None if nome_aba == "Todas" else nome_aba

            dados = self.consultar_checklist(
                data=data_iso,
                status=status,
                tarefa=tarefa,
                esteira=esteira_param
            )

            # Limpa a tabela PySide6
            table.setRowCount(0)

            for linha_idx, linha in enumerate(dados):
                table.insertRow(linha_idx)
                table.setItem(linha_idx, 0, QTableWidgetItem(str(linha.get("id_tarefa", ""))))
                table.setItem(linha_idx, 1, QTableWidgetItem(str(linha.get("tarefa", ""))))
                table.setItem(linha_idx, 2, QTableWidgetItem(str(linha.get("data_evento", ""))))
                table.setItem(linha_idx, 3, QTableWidgetItem(str(linha.get("status", ""))))
                table.setItem(linha_idx, 4, QTableWidgetItem(str(linha.get("responsavel", ""))))
                table.setItem(linha_idx, 5, QTableWidgetItem(str(linha.get("observacoes", ""))))
                data_att = self._formatar_data_atualizacao(linha.get("data_atualizacao", ""))
                table.setItem(linha_idx, 6, QTableWidgetItem(str(data_att)))
                table.setItem(linha_idx, 7, QTableWidgetItem(str(linha.get("esteira", ""))))
