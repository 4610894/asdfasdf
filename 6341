def get_outlook_folders():
    """
    Conecta ao Outlook e retorna uma lista com o caminho de todas as pastas e subpastas.
    """
    try:
        outlook = win32com.client.Dispatch("Outlook.Application").GetNamespace("MAPI")
        folders_list = []

        # Função recursiva para pegar subpastas dentro de pastas
        def map_subfolders(folder, path=""):
            for subfolder in folder.Folders:
                # Monta o caminho da pasta (ex: Caixa de Entrada/Projetos)
                current_path = f"{path}/{subfolder.Name}" if path else subfolder.Name
                folders_list.append(current_path)
                # Chama a recursão para caso a subpasta tenha mais subpastas
                map_subfolders(subfolder, current_path)

        # Iterar pelas contas (Stores) configuradas no Outlook
        for store in outlook.Stores:
            root_folder = store.GetRootFolder()
            # Começa a mapear a partir da raiz da conta
            map_subfolders(root_folder, root_folder.Name)
            
        return folders_list
    except Exception as e:
        print(f"Erro ao acessar o Outlook: {e}")
        return []

