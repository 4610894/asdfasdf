    def _formatar_data(self, *args):
        """
        Formata a string conforme a quantidade de dígitos
        digitados para o formato DD/MM/AAAA.
        """
        valor = self.data_var.get()
        # Remove tudo que não for dígito
        numeros = ''.join(filter(str.isdigit, valor))

        novo = ""
        # 0 a 2 dígitos: "DD" ou "D"
        if len(numeros) <= 2:
            novo = numeros
        # 3 ou 4 dígitos: "DD/MM" ou "DD/M"
        elif len(numeros) <= 4:
            novo = f"{numeros[:2]}/{numeros[2:]}"
        # 5 a 8 dígitos: "DD/MM/AAAA" (parcial se < 8)
        else:
            novo = f"{numeros[:2]}/{numeros[2:4]}/{numeros[4:8]}"

        # Evita sobrescrever se não mudou (reduz flicker/reentrância)
        if valor != novo:
            self.data_var.set(novo)

