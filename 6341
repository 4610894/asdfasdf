    def _buscar_dados_painel(self):
        """
        Retorna dados simulados em vez de consultar o banco de dados.
        O formato esperado da tupla é: (id_tarefa, tarefa, esteira_str, obs, status, peso)
        """
        dados_simulados = [
            (1, "Análise de Crédito Inicial", "Esteira A", "Prioridade alta - Cliente VIP", "Concluído", 10),
            (2, "Verificação de Documentos de Identidade", "Esteira A", None, "Em andamento", 5),
            (3, "Aprovação da Gerência", "Esteira A", "Aguardando retorno do comitê", "Pendente", 8),
            (4, "Auditoria Interna de Processos", "Esteira B", "Verificar conformidade com a nova norma", "Atraso", 15),
            (5, "Emissão de Contrato Físico", "Esteira B", None, "Pendente", 10),
            (6, "Assinatura Digital de Diretoria", "Esteira B", "Aguardando token", "Em andamento", 5),
            (7, "Validação no Sistema Legado", "Esteira C", "Sistema esteve instável na terça-feira", "Não se aplica", 0),
            (8, "Envio de Kit Boas-Vindas", "Esteira C", None, "Concluído", 5),
            (9, "Pesquisa de Satisfação", "Esteira C", None, "Concluído", 2)
        ]
        
        # Filtra os dados simulados para exibir apenas as esteiras passadas na inicialização da view
        dados_filtrados = []
        for linha in dados_simulados:
            esteira_str = linha[2]
            for est in self.esteiras:
                if est in esteira_str:
                    dados_filtrados.append(linha)
                    break
                    
        return dados_filtrados

    def carregar_painel(self):
        # Limpa o conteúdo atual do layout de colunas
        while self.colunas_layout.count():
            item = self.colunas_layout.takeAt(0)
            widget = item.widget()
            if widget is not None:
                widget.deleteLater()
                
        dados = self._buscar_dados_painel()
        
        if not dados:
            lbl = QLabel("Nenhuma tarefa encontrada.")
            lbl.setStyleSheet("font-family: Arial; font-size: 16px;")
            self.colunas_layout.addWidget(lbl)
            return
            
        COL_WIDTH = 525 # Mesma largura do original
        
        # Organiza dados por esteira (Lógica de negócio mantida)
        tarefas_por_esteira = {}
        for row in dados:
            id_tarefa, tarefa, esteira_str, obs, status, peso = row
            for est in self.esteiras:
                if est in esteira_str:
                    tarefas_por_esteira.setdefault(est, []).append((tarefa, status, obs, peso))
                    break 

        # Cria as colunas dinamicamente
        for esteira in self.esteiras:
            tarefas = tarefas_por_esteira.get(esteira, [])
            
            total_peso = sum(t[3] for t in tarefas)
            concluido_peso = sum(t[3] for t in tarefas if t[1] == 'Concluído')
            progresso_perc = (concluido_peso / total_peso) if total_peso > 0 else 0
            
            # Frame da coluna
            col_frame = QFrame()
            col_frame.setFixedWidth(COL_WIDTH)
            col_layout = QVBoxLayout(col_frame)
            col_layout.setAlignment(Qt.AlignmentFlag.AlignTop)
            
            # Cabeçalho da coluna (Gráfico + Título)
            header_layout = QVBoxLayout()
            header_layout.setAlignment(Qt.AlignmentFlag.AlignCenter)
            
            # Gráfico Circular Customizado
            grafico = CircularProgress(progresso_perc)
            header_layout.addWidget(grafico, alignment=Qt.AlignmentFlag.AlignCenter)
            
            # Título da Esteira
            lbl_esteira = QLabel(esteira)
            lbl_esteira.setStyleSheet("font-family: Arial; font-size: 18px; font-weight: bold; color: #1E3A8A;")
            header_layout.addWidget(lbl_esteira, alignment=Qt.AlignmentFlag.AlignCenter)
            
            col_layout.addLayout(header_layout)
            col_layout.addSpacing(15)
            
            # Lista de tarefas (Cards)
            for tarefa, status, obs, peso in tarefas:
                # Estilização do Card via CSS
                card = QFrame()
                card.setStyleSheet("""
                    QFrame {
                        background-color: white;
                        border: 1px solid #E5E7EB;
                        border-radius: 8px;
                    }
                """)
                card_layout = QHBoxLayout(card)
                card_layout.setContentsMargins(10, 10, 10, 10)
                
                cor_status = self.status_colors.get(status, "#000000")
                
                # Bolinha de status via HTML
                lbl_status = QLabel(f"<span style='color: {cor_status}; font-size: 18px;'>●</span>")
                lbl_status.setStyleSheet("border: none; background: transparent;")
                card_layout.addWidget(lbl_status)
                
                # Texto da tarefa
                lbl_tarefa = QLabel(tarefa)
                lbl_tarefa.setStyleSheet("font-family: Arial; font-size: 13px; color: #374151; border: none; background: transparent;")
                lbl_tarefa.setWordWrap(True) # Substitui o wraplength do Tkinter
                card_layout.addWidget(lbl_tarefa, 1) # weight 1 para ocupar espaço
                
                # Ícone de Observação com Tooltip nativo
                if obs and str(obs).strip() and obs != "None":
                    info_icon = QLabel("ℹ️")
                    info_icon.setStyleSheet("color: #6B7280; font-size: 16px; border: none; background: transparent;")
                    info_icon.setCursor(QCursor(Qt.CursorShape.PointingHandCursor))
                    # Tooltip nativo do PySide6 substitui as funções customizadas _mostrar_tooltip e _esconder_tooltip
                    info_icon.setToolTip(f"<span style='font-family: Arial; font-size: 12px;'>{obs}</span>") 
                    card_layout.addWidget(info_icon)
                
                col_layout.addWidget(card)
            
            self.colunas_layout.addWidget(col_frame)

