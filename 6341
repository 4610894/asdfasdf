    def _carregar_arquivo(self):
        """
        Abre o explorador de arquivos para o usuário selecionar uma planilha
        e a converte em um DataFrame do Pandas.
        """
        # Abre a janela para buscar o arquivo
        caminho_arquivo = filedialog.askopenfilename(
            title="Selecione o arquivo de operações",
            filetypes=[("Arquivos Excel", "*.xlsx *.xls"),
                        ("Arquivos CSV", "*.csv"),
                        ("Todos os arquivos", "*.*")])

        # Se o usuário fechar a janela de busca sem escolher nada, encerra a função
        if not caminho_arquivo:
            return

        try:
            # Lê o arquivo dependendo da extensão
            if caminho_arquivo.endswith('.csv'):
                df = pd.read_csv(caminho_arquivo, sep=';', encoding='utf-8') 
            else:
                df = pd.read_excel(caminho_arquivo)

            nome_do_arquivo = os.path.basename(caminho_arquivo)
            self._processar_e_comparar_dados(df, nome_do_arquivo)

        except Exception as e:
            # Se der erro (arquivo corrompido, formato errado, etc), avisa o usuário
            messagebox.showerror("Erro", f"Não foi possível ler o arquivo.\nErro: {str(e)}")
            return None

