import sys
from PySide6.QtCore import QObject, Signal
from PySide6.QtWidgets import QTextEdit

class Logger(QObject):
    # Define um sinal que carrega uma string
    log_signal = Signal(str)

    def __init__(self, log_widget: QTextEdit = None):
        super().__init__()
        self.log_widget = log_widget
        # Conecta o sinal interno à função de escrever no widget
        self.log_signal.connect(self._append_text)

    def register_log_widget(self, log_widget: QTextEdit):
        self.log_widget = log_widget
        # Reconecta caso o widget mude
        try:
            self.log_signal.disconnect()
        except TypeError:
            pass # Se não havia conexão anterior
        self.log_signal.connect(self._append_text)
        self.log("Logger inicializado (PyQt).")

    def _append_text(self, msg: str):
        """Método executado na thread da GUI automaticamente via sinal."""
        if self.log_widget:
            self.log_widget.append(msg)
            # Rola para o final
            scrollbar = self.log_widget.verticalScrollBar()
            scrollbar.setValue(scrollbar.maximum())

    def log(self, message: str):
        """Pode ser chamado de qualquer thread com segurança."""
        print(message) # Mantém print no console
        # Emite o sinal. O Qt garante que _append_text rode na thread principal.
        self.log_signal.emit(message)

    def start_pumping(self):
        # Em Qt, não precisamos de 'pumping' manual, os sinais lidam com isso.
        # Mantive o método apenas para compatibilidade de interface se necessário.
        pass












import pyodbc
from PySide6.QtWidgets import QMessageBox
import config

class DatabaseManager:
    def __init__(self):
        self.conn = None
        self.cursor = None
        # A conexão é iniciada, mas erros são tratados visualmente na UI
        # O ideal seria não bloquear a UI na inicialização, mas mantive a lógica original.
        self.connect()

    def connect(self):
        try:
            connection_string = (
                'DRIVER={ODBC Driver 17 for SQL Server};'
                f'SERVER={config.SERVER};'
                f'DATABASE={config.DATABASE};'
                f'UID={config.USERNAME};'
                f'PWD={config.PASSWORD}'
            )
            # Nota: pyodbc pode travar a GUI se o servidor demorar. 
            # Em produção, mover isso para uma QThread é recomendado.
            self.conn = pyodbc.connect(connection_string, timeout=5)
            self.cursor = self.conn.cursor()
            print('Conexão com o banco de dados estabelecida.')
        except pyodbc.Error as e:
            msg = QMessageBox()
            msg.setIcon(QMessageBox.Icon.Critical)
            msg.setWindowTitle("Erro de Conexão")
            msg.setText("Não foi possível conectar ao banco de dados.")
            msg.setDetailedText(str(e))
            msg.exec()
            self.conn = None
            self.cursor = None
    
    def close(self):
        if self.conn:
            self.conn.close()
            print('Conexão com o banco de dados fechada.')
    
    def is_connected(self):
        return self.conn is not None













