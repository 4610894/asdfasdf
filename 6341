    def _carregar_arquivo(self):
        """Abre o explorador e converte em DataFrame."""
        caminho_arquivo = filedialog.askopenfilename(
            title="Selecione o arquivo de operações",
            filetypes=[("Arquivos Excel", "*.xlsx *.xls"),
                       ("Arquivos CSV", "*.csv"),
                       ("Todos os arquivos", "*.*")]
        )

        if not caminho_arquivo:
            return

        try:
            if caminho_arquivo.endswith('.csv'):
                df = pd.read_csv(caminho_arquivo, sep=';', encoding='utf-8') 
            else:
                df = pd.read_excel(caminho_arquivo)

            nome_do_arquivo = os.path.basename(caminho_arquivo)
            
            # Chama o método que apenas PREPARA os dados e INICIA a thread
            self._preparar_dados_e_iniciar_busca(df, nome_do_arquivo)

        except Exception as e:
            messagebox.showerror("Erro", f"Não foi possível ler o arquivo.\nErro: {str(e)}")

    def _preparar_dados_e_iniciar_busca(self, df_raw, nome_arquivo):
        """Trata o DF, abre a janela de progresso e inicia a Thread de busca."""
        df = df_raw.copy()
        
        # Tratamento de dados original
        df['Agência'] = df['Agência'].astype(str).str.zfill(4)
        df['Conta'] = df['Conta'].astype(str).str.zfill(5)
        df['Dac'] = df['Dac'].astype(str).str.zfill(1)
        df['CPF/CNPJ'] = df['CPF/CNPJ'].astype(str).str.zfill(14)

        df['Agência.1'] = df['Agência.1'].astype(str).str.zfill(4)
        df['Conta.1'] = df['Conta.1'].astype(str).str.zfill(5)
        df['Dac.1'] = df['Dac.1'].astype(str).str.zfill(1)
        df['CPF/CNPJ.1'] = df['CPF/CNPJ.1'].astype(str).str.zfill(14)

        df['conta débito'] = df['Agência'] + '/' + df['Conta'] + '-' + df['Dac']
        df['conta crédito'] = df['Agência.1'] + '/' + df['Conta.1'] + '-' + df['Dac.1']

        df = df[['conta débito', 'CPF/CNPJ', 'conta crédito', 'CPF/CNPJ.1', 'Valor']].rename(
            columns={
                'CPF/CNPJ': 'cnpj débito',
                'CPF/CNPJ.1': 'cnpj crédito',
                'Valor': 'valor'
            }
        )

        # Extrai APENAS as contas únicas para não buscar a mesma conta na AWS várias vezes
        contas_unicas = pd.concat([df['conta débito'], df['conta crédito']]).unique().tolist()

        # Abre a janela de progresso na Main Thread
        total_contas = len(contas_unicas)
        self.progresso_gui = ProgressWindow(self, total_contas) # Assumindo que self é a janela principal

        # Inicia a Thread para buscar as contas
        threading.Thread(
            target=self._worker_consulta_aws, 
            args=(contas_unicas, df, nome_arquivo), 
            daemon=True
        ).start()

    def _worker_consulta_aws(self, contas_unicas, df_tratado, nome_arquivo):
        """Roda em background. Busca as contas e avisa quando terminar."""
        db_real = {}
        total = len(contas_unicas)

        try:

            for i, conta in enumerate(contas_unicas, 1):
                # SIMULANDO CONSULTA NA AWS:
                sleep(1.5) # Simula o tempo de rede
                
                # Aqui você faria a consulta real. Simulação de retorno:
                if conta in ['0123/01234-1', '0321/05432-2', '0001/00001-1', '0999/09999-9']:
                    db_real[conta] = '000000000' + conta.split('/')[1].split('-')[0] # Simula um CNPJ
                
                # Atualiza a interface (thread-safe)
                self.progresso_gui.after(0, self.progresso_gui.atualizar, i, total)

            # Ao terminar, FECHA O POPUP e envia os dados para a função final
            self.progresso_gui.after(0, self.progresso_gui.destroy)
            
            # O self.after garante que a interface gráfica e a comparação sejam feitas na Main Thread
            self.after(0, lambda: self._processar_e_comparar_dados(df_tratado, db_real, nome_arquivo))
        
        except:
            self.after(0, lambda: messagebox.showwarning(
                    "Credenciais AWS Inválidas", 
                    "Suas credenciais da AWS expiraram ou são inválidas.\n\nPor favor, atualize suas credenciais na aba 'Credenciais AWS' e tente novamente."
                ))


    def _processar_e_comparar_dados(self, df, db_real, nome_arquivo):
        """Executa após a Thread terminar. Compara os dados e atualiza a GUI."""
        
        total_operacoes = len(df)
        qtd_batidas = 0
        qtd_nao_encontradas = 0
        qtd_incorretas = 0
        
        linhas_processadas = []
        dados_para_banco = []

        # Lógica de Comparação Linha a Linha usando o db_real trazido da AWS
        for index, row in df.iterrows():
            c_debito = row['conta débito']
            cnpj_debito = row['cnpj débito']
            c_credito = row['conta crédito']
            cnpj_credito = row['cnpj crédito']
            valor = row['valor']

            try:
                valor_float = float(valor)
                valor_str = f"{valor_float:,.2f}"
                valor_formatado = f"R$ {valor_str.replace(',', 'X').replace('.', ',').replace('X', '.')}"
            except ValueError:
                valor_formatado = f"R$ {valor}"

            # Validar Débito
            status_deb = "OK"
            if c_debito not in db_real:
                status_deb = "NÃO ENCONTRADA"
            elif db_real[c_debito] != cnpj_debito:
                status_deb = "INCORRETA"

            # Validar Crédito
            status_cred = "OK"
            if c_credito not in db_real:
                status_cred = "NÃO ENCONTRADA"
            elif db_real[c_credito] != cnpj_credito:
                status_cred = "INCORRETA"

            # Definir o Status Final
            if status_deb == "OK" and status_cred == "OK":
                status_final = "✅ Batida"
                observacao = "OK"
                qtd_batidas += 1
                tag_visual = 'normal'
                prioridade = 3
            elif "NÃO ENCONTRADA" in status_deb or "NÃO ENCONTRADA" in status_cred:
                status_final = "⚠️ Não encontrada"
                observacao = f"D: {status_deb} | C: {status_cred}"
                qtd_nao_encontradas += 1
                tag_visual = 'nao_encontrada'
                prioridade = 2
            else:
                status_final = "❌ Incorreta"
                observacao = f"D: {status_deb} | C: {status_cred}"
                qtd_incorretas += 1
                tag_visual = 'incorreta'
                prioridade = 1

            dados_para_banco.append({
                'conta_debito': c_debito,
                'cnpj_debito': cnpj_debito,
                'conta_credito': c_credito,
                'cnpj_credito': cnpj_credito,
                'valor': valor,
                'status': status_final.replace('✅ ', '').replace('⚠️ ', '').replace('❌ ', ''), 
                'observacao': observacao
            })

            linhas_processadas.append({
                'valores': (c_debito, cnpj_debito, c_credito, cnpj_credito, valor_formatado, status_final, observacao, '☐', '☐'),
                'tag_visual': tag_visual,
                'prioridade': prioridade
            })

        # Ordena e insere na tela
        linhas_processadas.sort(key=lambda x: x['prioridade'])

        for item in self.tree.get_children():
            self.tree.delete(item)

        for index, item in enumerate(linhas_processadas):
            tag_base = item['tag_visual']
            sufixo = '_par' if index % 2 == 0 else '_impar'
            tag_final = 'par' if tag_base == 'normal' and index % 2 == 0 else \
                        'impar' if tag_base == 'normal' else f"{tag_base}{sufixo}"
                
            self.tree.insert('', 'end', values=item['valores'], tags=(tag_final,))

        # Atualiza Cards
        self.val_operacoes.set(str(total_operacoes))
        self.val_batidas.set(str(qtd_batidas))
        self.val_nao_encontradas.set(str(qtd_nao_encontradas))
        self.val_incorretas.set(str(qtd_incorretas))

        # Salva no banco
        self._registrar_log(nome_arquivo, dados_para_banco)


