        btn_carregar = ctk.CTkButton(janela_hist, text="Carregar Lote Selecionado", 
                                     command=_carregar_selecionado, 
                                     fg_color=config.AZUL, hover_color=config.AZUL_HOVER)
        btn_carregar.pack(pady=15)
        
        # Opcional: Permitir carregar com duplo clique
        tree_hist.bind('<Double-1>', lambda event: _carregar_selecionado())

    def _iniciar_consulta_individual(self, conta_digitada, cnpj_entry):
        """Inicia o processo de busca para uma única conta."""
        conta_digitada = conta_digitada.strip()

        if not conta_digitada:
            messagebox.showwarning("Aviso", "Por favor, digite uma conta.")
            return

        # Limpa o campo de CNPJ caso já tenha alguma consulta anterior lá
        cnpj_entry.configure(state="normal")
        cnpj_entry.delete(0, 'end')
        cnpj_entry.configure(state="disabled")

        # Inicia a janela de progresso (Total de 1 item)
        self.progresso_gui = ProgressWindow(self, 1)

        # Inicia a thread para não travar a aba de configurações
        threading.Thread(
            target=self._worker_consulta_individual,
            args=(conta_digitada, cnpj_entry),
            daemon=True
        ).start()

    def _worker_consulta_individual(self, conta, cnpj_entry):
        """Roda em background para consultar apenas uma conta na AWS."""
        try:
            # SIMULANDO CONSULTA NA AWS:
            sleep(1.5) # Simula o delay da rede
            
            # Aqui você faria a sua chamada real para a AWS
            # Exemplo simulado de retorno:
            if conta in ['0123/01234-1', '0321/05432-2', '0001/00001-1', '0999/09999-9']:
                cnpj_encontrado = '000000000' + conta.split('/')[1].split('-')[0]
            else:
                cnpj_encontrado = "NÃO ENCONTRADO"

            # Atualiza o contador do progresso (1/1)
            self.progresso_gui.after(0, self.progresso_gui.atualizar, 1, 1)

            # Fecha a janela de progresso
            self.progresso_gui.after(0, self.progresso_gui.destroy)

            # Envia o resultado de volta para a Thread principal atualizar a Entry
            self.after(0, lambda: self._atualizar_resultado_individual(cnpj_entry, cnpj_encontrado))
        
        except:
            self.after(0, lambda: messagebox.showwarning(
                        "Credenciais AWS Inválidas", 
                        "Suas credenciais da AWS expiraram ou são inválidas.\n\nPor favor, atualize suas credenciais na aba 'Credenciais AWS' e tente novamente."
                    ))
            self.after(0, lambda: self._restaurar_entry_apos_erro(cnpj_entry))

    def _atualizar_resultado_individual(self, cnpj_entry, resultado):
        """Atualiza o campo do CustomTkinter com o resultado final."""
        # Habilita o campo para edição, insere o valor e desabilita novamente
        cnpj_entry.configure(state="normal")
        cnpj_entry.delete(0, 'end')
        cnpj_entry.insert(0, resultado)
        
        # Se não quiser que o texto fique apagado visualmente, você pode 
        # mudar a cor da fonte antes de dar disable, ou usar state="readonly"
        cnpj_entry.configure(state="disabled")

    def _restaurar_entry_apos_erro(self, cnpj_entry):
        """Caso a consulta individual falhe, deixa o campo pronto para nova tentativa."""
        cnpj_entry.configure(state="normal")
        cnpj_entry.delete(0, 'end')
        cnpj_entry.configure(state="disabled")



