import win32com.client
from datetime import datetime

def listar_emails_hoje():
    # 1. Conecta ao aplicativo Outlook
    outlook = win32com.client.Dispatch("Outlook.Application").GetNamespace("MAPI")
    
    # 2. Seleciona a Caixa de Entrada (6 é o código interno para Inbox)
    inbox = outlook.GetDefaultFolder(6)
    mensagens = inbox.Items
    
    # 3. Ordena pela ordem de chegada (False = do mais antigo para o mais novo)
    mensagens.Sort("[ReceivedTime]", False)
    
    # 4. Cria o filtro para pegar apenas os e-mails de hoje
    hoje = datetime.now().strftime('%d/%m/%Y')
    filtro = f"[ReceivedTime] >= '{hoje}'"
    
    # Aplica o filtro
    mensagens_hoje = mensagens.Restrict(filtro)
    
    print(f"--- E-mails recebidos hoje ({hoje}) ---\n")
    
    contador = 0
    # 5. Percorre os e-mails filtrados e printa o assunto
    for msg in mensagens_hoje:
        try:
            # Formata a hora para ficar fácil de ler
            hora_chegada = msg.ReceivedTime.strftime('%H:%M')
            print(f"[{hora_chegada}] {msg.Subject}")
            contador += 1
        except Exception:
            # Ignora itens da caixa de entrada que não são e-mails normais (ex: convites de reunião em branco)
            continue
            
    if contador == 0:
        print("Nenhum e-mail recebido hoje até o momento.")

if __name__ == "__main__":
    listar_emails_hoje()
