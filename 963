            sucesso = self._inserir_bd(novo_sac, conta_mov_formatada, conta_esp_formatada, novo_cci)
            if sucesso:
                messagebox.showinfo("Sucesso", "Registro inserido com sucesso!", parent=edit_window)
                edit_window.destroy()
                self._consultar_contas() 

        ctk.CTkButton(edit_window, text="Salvar alteração", command=salvar, fg_color=config.AZUL, hover_color=config.AZUL_HOVER).grid(row=4, column=0, columnspan=2, padx=10, pady=15)

    def _inserir_bd(self, sac, conta_mov_formatada, conta_esp_formatada, cci_formatado):
        """Insere um novo registro cruzado em relacao_clientes_inr e relacao_clientes_cci.
        """

        if not self.db_manager or not self.db_manager.is_connected():
            self.logger.log("ERRO: Não é possível inserir. Sem conexão com o banco de dados.")
            return False

        try:
            cursor = self.db_manager.cursor

            # Verifica se já existe na tabela pai (INR)
            cursor.execute("SELECT COUNT(*) FROM liq.RELACAO_CLIENTES_INR WHERE cd_sac = ?", sac)
            if cursor.fetchone()[0] > 0:
                messagebox.showwarning("Aviso", "Este SAC já está registrado. Para adicionar um CCI a ele, utilize o botão 'Alterar'.")
                return False

            # 1. Inserir na tabela INR primeiro (Independente se o usuário preencheu as contas, o SAC deve existir lá)
            colunas_inr = ["cd_sac"]
            valores_inr = ["?"]
            parametros_inr = [sac]

            if conta_mov_formatada:
                colunas_inr.append("conta_movimento")
                valores_inr.append("?")
                parametros_inr.append(conta_mov_formatada)

            if conta_esp_formatada:
                colunas_inr.append("conta_espelho")
                valores_inr.append("?")
                parametros_inr.append(conta_esp_formatada)

            query_inr = f"""
                INSERT INTO liq.RELACAO_CLIENTES_INR ({', '.join(colunas_inr)}) 
                VALUES ({', '.join(valores_inr)})
            """
            cursor.execute(query_inr, tuple(parametros_inr))

            # 2. Inserir na tabela CCI se houver dado correspondente
            if cci_formatado:
                query_cci = "INSERT INTO relacao_clientes_cci (cd_sac, cd_cci) VALUES (?, ?)"
                cursor.execute(query_cci, (sac, cci_formatado))

            self.db_manager.conn.commit()
            return True

        except pyodbc.Error as e:
            self.logger.log(f"ERRO CRÍTICO ao inserir a conta {sac}: {e}")
            return False
        except Exception as e:
            self.logger.log(f"ERRO INESPERADO ao inserir a conta {sac}: {e}")
            return False
