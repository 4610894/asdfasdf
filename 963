            conta_mov_formatada = None
            conta_esp_formatada = None

            conta_mov_limpa = novo_conta_mov.replace('/', '').replace('-', '').strip()
            if conta_mov_limpa:
                if len(conta_mov_limpa) != 10 or not conta_mov_limpa.isdigit():
                    messagebox.showwarning("Aviso", "A Conta Movimento deve conter exatamente 10 números.", parent=edit_window)
