    # =========== FUNÇÕES TREEVIEW =========== #
    def _consultar_contas(self):
        """Consulta unindo as tabelas de contas (INR) e CCI com um LEFT JOIN."""

        conn = self.db_manager.conn
        cursor = conn.cursor()

        sac = self.sac_var.get().strip()
        mov = self.conta_mov_var.get().strip()
        esp = self.conta_esp_var.get().strip()
        cci = self.cci_var.get().strip()

        # O JOIN assegura que mesmo SACs sem CCI aparecerão
        query = """
            SELECT i.cd_sac, i.conta_movimento, i.conta_espelho, c.cd_cci
            FROM liq.RELACAO_CLIENTES_INR i
            LEFT JOIN relacao_clientes_cci c ON i.cd_sac = c.cd_sac
            WHERE 1=1
        """

        if sac: query += f" AND i.cd_sac LIKE '%{sac}%'"
        if mov: query += f" AND i.conta_movimento LIKE '%{mov}%'"
        if esp: query += f" AND i.conta_espelho LIKE '%{esp}%'"
        if cci: query += f" AND c.cd_cci LIKE '%{cci}%'"

        cursor.execute(query)
        registros = cursor.fetchall()

        # limpa treeview
        for item in self.tree.get_children():
            self.tree.delete(item)

        # insere registros
        for index, (rsac, rconta_mov, rconta_esp, rcci) in enumerate(registros):
            tag = 'par' if index % 2 == 0 else 'impar'
            
            rsac_view = rsac if rsac else ""
            rconta_mov_view = rconta_mov if rconta_mov else ""
            rconta_esp_view = rconta_esp if rconta_esp else ""
            rcci_view = rcci if rcci else ""
            
            self.tree.insert("", "end", values=(rsac_view, rconta_mov_view, rconta_esp_view, rcci_view), tags=(tag,))


    def _alterar_dados(self):
        selecionado = self.tree.selection()
        if not selecionado:
            return

        item = self.tree.item(selecionado[0], "values")
        sac_atual, conta_mov_atual, conta_esp_atual, cci_atual = item

        # --- Janela pop-up de edição ---
        edit_window = ctk.CTkToplevel(self)
        edit_window.title("Editar Registro")
        edit_window.grab_set() 
        edit_window.focus_force() 

        ctk.CTkLabel(edit_window, text="SAC").grid(row=0, column=0, padx=10, pady=5)
        sac_entry = ctk.CTkEntry(edit_window)
        sac_entry.insert(0, sac_atual)
        sac_entry.grid(row=0, column=1, padx=10, pady=5)

        ctk.CTkLabel(edit_window, text="Conta Movimento").grid(row=1, column=0, padx=10, pady=5)
        conta_mov_entry = ctk.CTkEntry(edit_window)
        conta_mov_entry.insert(0, conta_mov_atual if conta_mov_atual not in ("None", "") else "")
        conta_mov_entry.grid(row=1, column=1, padx=10, pady=5)

        ctk.CTkLabel(edit_window, text="Conta Espelho").grid(row=2, column=0, padx=10, pady=5)
        conta_esp_entry = ctk.CTkEntry(edit_window)
        conta_esp_entry.insert(0, conta_esp_atual if conta_esp_atual not in ("None", "") else "")
        conta_esp_entry.grid(row=2, column=1, padx=10, pady=5)

        ctk.CTkLabel(edit_window, text="CCI").grid(row=3, column=0, padx=10, pady=5)
        cci_entry = ctk.CTkEntry(edit_window)
        cci_entry.insert(0, cci_atual if cci_atual not in ("None", "") else "")
        cci_entry.grid(row=3, column=1, padx=10, pady=5)

        def salvar():
            novo_sac = sac_entry.get().strip()
            novo_conta_mov = conta_mov_entry.get()
            nova_conta_esp = conta_esp_entry.get()
            novo_cci = cci_entry.get().strip()

            if not novo_sac:
                messagebox.showwarning("Aviso", "O campo SAC não pode ficar vazio.", parent=edit_window)
                return

            conta_mov_formatada = None
            conta_esp_formatada = None

            # Validação
            conta_mov_limpa = novo_conta_mov.replace('/', '').replace('-', '').strip()
            if conta_mov_limpa:
                if len(conta_mov_limpa) != 10 or not conta_mov_limpa.isdigit():
                    messagebox.showwarning("Aviso", "A Conta Movimento deve conter exatamente 10 números.", parent=edit_window)
                    return
                conta_mov_formatada = f"{conta_mov_limpa[:4]}/{conta_mov_limpa[4:9]}-{conta_mov_limpa[-1]}"

            conta_esp_limpa = nova_conta_esp.replace('/', '').replace('-', '').strip()
            if conta_esp_limpa:
                if len(conta_esp_limpa) != 10 or not conta_esp_limpa.isdigit():
                    messagebox.showwarning("Aviso", "A Conta Espelho deve conter exatamente 10 números.", parent=edit_window)
                    return
                conta_esp_formatada = f"{conta_esp_limpa[:4]}/{conta_esp_limpa[4:9]}-{conta_esp_limpa[-1]}"

            conn = self.db_manager.conn
            cursor = conn.cursor()

            try:
                # 1. Atualizar Tabela INR (Pai)
                set_clauses_inr = ["cd_sac = ?"]
                params_inr = [novo_sac]

                if conta_mov_formatada:
                    set_clauses_inr.append("conta_movimento = ?")
                    params_inr.append(conta_mov_formatada)
                else:
                    set_clauses_inr.append("conta_movimento = NULL")

                if conta_esp_formatada:
                    set_clauses_inr.append("conta_espelho = ?")
                    params_inr.append(conta_esp_formatada)
                else:
                    set_clauses_inr.append("conta_espelho = NULL")

                params_inr.append(sac_atual)

                query_inr = f"""
                    UPDATE liq.RELACAO_CLIENTES_INR
                    SET {', '.join(set_clauses_inr)}
                    WHERE cd_sac = ?
                """
                cursor.execute(query_inr, tuple(params_inr))

                # 2. Atualizar Tabela CCI (Filha)
                cursor.execute("SELECT COUNT(*) FROM relacao_clientes_cci WHERE cd_sac = ?", novo_sac)
                cci_existe = cursor.fetchone()[0] > 0

                if novo_cci:
                    if cci_existe:
                        cursor.execute("UPDATE relacao_clientes_cci SET cd_cci = ? WHERE cd_sac = ?", (novo_cci, novo_sac))
                    else:
                        cursor.execute("INSERT INTO relacao_clientes_cci (cd_sac, cd_cci) VALUES (?, ?)", (novo_sac, novo_cci))
                else:
                    # Se esvaziou o campo CCI, deletamos a relação na tabela filha
                    if cci_existe:
                        cursor.execute("DELETE FROM relacao_clientes_cci WHERE cd_sac = ?", novo_sac)

                conn.commit()

                # Atualiza treeview e fecha
                self.tree.item(selecionado[0], values=(novo_sac, conta_mov_formatada or "", conta_esp_formatada or "", novo_cci))
                messagebox.showinfo("Sucesso", "Registro alterado com sucesso!", parent=edit_window)
                edit_window.destroy()
            
            except Exception as e:
                self.logger.log(f"ERRO ao alterar registro {sac_atual}: {e}")
                messagebox.showerror("Erro", f"Ocorreu um erro ao alterar: {e}", parent=edit_window)

        def deletar():
            if messagebox.askyesno("Confirmar", "Tem certeza que deseja deletar este registro de ambas as tabelas?", parent=edit_window):
                conn = self.db_manager.conn
                cursor = conn.cursor()

                try:
                    # Deleta da filha primeiro para respeitar integridade referencial
                    cursor.execute("DELETE FROM relacao_clientes_cci WHERE cd_sac = ?", sac_atual)
                    # Depois deleta da pai
                    cursor.execute("DELETE FROM liq.RELACAO_CLIENTES_INR WHERE cd_sac = ?", sac_atual)
                    conn.commit()

                    self.tree.delete(selecionado[0])
                    messagebox.showinfo("Sucesso", "Registro deletado com sucesso!", parent=self)
                    edit_window.destroy()
                except Exception as e:
                    self.logger.log(f"ERRO ao deletar registro {sac_atual}: {e}")
                    messagebox.showerror("Erro", f"Ocorreu um erro ao deletar: {e}", parent=edit_window)

        ctk.CTkButton(edit_window, text="Salvar alteração", command=salvar, fg_color=config.AZUL, hover_color=config.AZUL_HOVER).grid(row=4, column=0, padx=10, pady=15)
        ctk.CTkButton(edit_window, text="Deletar", command=deletar, fg_color="red").grid(row=4, column=1, padx=10, pady=15)


